---
/*
 * Flagged placeholder imagery — NOT final art.
 * Exists so we can validate composition, cropping, overlay/scrim, navigation
 * over image, and section rhythm before real environmental photography lands.
 * Every instance carries a visible "PLACEHOLDER" flag so it is never mistaken
 * for finished work (Creative Direction §11, §17 — never pretend imagery is final).
 *
 * Slotted children render above the image + scrim, vertically managed by the
 * caller (the component fills its container; sizing is passed via `class`).
 */
interface Props {
  src: string;
  alt: string;
  note: string;            // the intended-shot direction, shown in the flag
  class?: string;          // container sizing / shape
  scrimClass?: string;     // overlay gradient for text contrast; "" disables
  eager?: boolean;
}
const {
  src,
  alt,
  note,
  class: className = "",
  scrimClass = "bg-gradient-to-t from-black/55 via-black/20 to-black/10",
  eager = false,
} = Astro.props;
---

<figure class={`relative overflow-hidden isolate m-0 ${className}`}>
  <img
    src={src}
    alt={alt}
    loading={eager ? "eager" : "lazy"}
    decoding="async"
    class="absolute inset-0 h-full w-full object-cover"
  />
  {scrimClass && <div class={`absolute inset-0 ${scrimClass}`} aria-hidden="true"></div>}

  <span class="placeholder-flag">Placeholder · {note}</span>

  <div class="relative z-10 h-full"><slot /></div>
</figure>
