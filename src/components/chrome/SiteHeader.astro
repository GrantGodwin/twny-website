---
import Wordmark from "./Wordmark.astro";
import ThemeToggle from "./ThemeToggle.astro";

const nav = [
  { label: "Productivity", href: "/productivity" },
  { label: "Pricing", href: "/pricing" },
  { label: "Contact", href: "/contact" },
];

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  class="sticky top-0 z-40 border-b border-line bg-sand/90 backdrop-blur-sm"
>
  <div
    class="mx-auto max-w-6xl px-5 sm:px-8 h-16 flex items-center justify-between gap-6"
  >
    <Wordmark class="text-2xl" />

    <nav aria-label="Primary" class="flex items-center gap-5 sm:gap-7">
      {
        nav.map((item) => {
          const active = path === item.href;
          return (
            <a
              href={item.href}
              aria-current={active ? "page" : undefined}
              class={`font-body text-sm transition-colors ${
                active
                  ? "text-mineral"
                  : "text-steel hover:text-ink"
              }`}
            >
              {item.label}
            </a>
          );
        })
      }
      <a
        href="/contact"
        class="hidden sm:inline-flex items-center bg-ember hover:bg-ember-strong text-white text-sm font-medium px-3.5 py-2 rounded-sm transition-colors"
      >
        Tell us what you need
      </a>
      <ThemeToggle />
    </nav>
  </div>
</header>
