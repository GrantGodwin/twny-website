---
import Wordmark from "./Wordmark.astro";
import Button from "../ui/Button.astro";

interface Props {
  // When true the header floats transparently over an immersive hero and
  // resolves to the solid bar on scroll. Default: solid bar (all other pages).
  overHero?: boolean;
}
const { overHero = false } = Astro.props;

const nav = [
  { label: "Services", href: "/services" },
  { label: "Contact", href: "/contact" },
];

const email = "hello@twny.com.au";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  class:list={[
    "site-header sticky top-0 z-40 border-b border-line bg-sand/90 backdrop-blur-sm",
    overHero && "site-header--over-hero",
  ]}
>
  <div
    class="mx-auto max-w-6xl px-5 sm:px-8 h-16 flex items-center justify-between gap-6"
  >
    <Wordmark class="site-wordmark text-[2.1rem]" animate={overHero} />

    <nav
      aria-label="Primary"
      class="hidden sm:flex flex-1 items-center justify-end gap-8"
    >
      {
        nav.map((item) => {
          const active = path === item.href;
          return (
            <a
              href={item.href}
              aria-current={active ? "page" : undefined}
              class:list={[
                "site-link font-body text-[0.9375rem] font-medium transition-colors duration-200 ease-out",
                active ? "text-mineral" : "text-steel hover:text-ink",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    {/* desktop/tablet CTA — always visible and static (no scroll-reveal) */}
    <div class="hidden items-center sm:flex ml-8">
      <Button href={`mailto:${email}`} variant="ember">Get in touch</Button>
    </div>

    <button
      type="button"
      class="site-menu-toggle sm:hidden inline-flex h-10 w-10 items-center justify-center text-ink"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <span class="menu-icon" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </div>

  <div id="mobile-menu" class="mobile-menu sm:hidden" hidden>
    <nav
      aria-label="Mobile"
      class="flex flex-col border-t border-line bg-paper px-5 py-4"
    >
      {
        nav.map((item) => {
          const active = path === item.href;
          return (
            <a
              href={item.href}
              aria-current={active ? "page" : undefined}
              class:list={[
                "border-b border-line py-3.5 font-body text-base transition-colors duration-200 ease-out",
                active ? "text-mineral" : "text-steel hover:text-ink",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
      <div class="pt-5">
        <Button href={`mailto:${email}`} variant="ember" class="w-full justify-center">
          Get in touch
        </Button>
      </div>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector(".site-header");

  function syncScroll() {
    if (header?.classList.contains("site-header--over-hero")) {
      header.classList.toggle("is-scrolled", window.scrollY > 24);
    }
  }
  syncScroll();
  window.addEventListener("scroll", syncScroll, { passive: true });

  const toggle = document.querySelector<HTMLButtonElement>(".site-menu-toggle");
  const menu = document.getElementById("mobile-menu") as HTMLElement | null;
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!isOpen));
      toggle.setAttribute("aria-label", isOpen ? "Open menu" : "Close menu");
      menu.hidden = isOpen;
    });
  }
</script>
