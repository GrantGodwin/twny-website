---
import Wordmark from "./Wordmark.astro";

interface Props {
  // When true the header floats transparently over an immersive hero and
  // resolves to the solid bar on scroll. Default: solid bar (all other pages).
  overHero?: boolean;
}
const { overHero = false } = Astro.props;

const nav = [
  { label: "Services", href: "/#services" },
  { label: "Pricing", href: "/pricing" },
  { label: "Contact", href: "/contact" },
];

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  class:list={[
    "site-header sticky top-0 z-40 border-b border-line bg-sand/90 backdrop-blur-sm",
    overHero && "site-header--over-hero",
  ]}
>
  <div
    class="mx-auto max-w-6xl px-5 sm:px-8 h-16 flex items-center justify-between gap-6"
  >
    <Wordmark class="site-wordmark text-3xl" />

    <nav aria-label="Primary" class="flex items-center gap-5 sm:gap-7">
      {
        nav.map((item) => {
          const active = path === item.href;
          return (
            <a
              href={item.href}
              aria-current={active ? "page" : undefined}
              class:list={[
                "site-link font-body text-sm transition-colors",
                active ? "text-mineral" : "text-steel hover:text-ink",
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
      <a
        href="/contact"
        class="hidden sm:inline-flex items-center bg-ember hover:bg-ember-strong text-white text-sm font-medium px-3.5 py-2 rounded-sm transition-colors"
      >
        Start a conversation
      </a>
    </nav>
  </div>
</header>

{
  overHero && (
    <script>
      const header = document.querySelector(".site-header--over-hero");
      if (header) {
        const sync = () =>
          header.classList.toggle("is-scrolled", window.scrollY > 24);
        sync();
        window.addEventListener("scroll", sync, { passive: true });
      }
    </script>
  )
}
