---
import Wordmark from "./Wordmark.astro";

const nav = [
  { label: "Services", href: "/services" },
  { label: "Contact", href: "/contact" },
];

const year = new Date().getFullYear();
---

<footer class="border-t border-line bg-paper">
  <div class="mx-auto max-w-6xl px-5 sm:px-8 py-12">
    <div
      class="grid gap-10 sm:grid-cols-[1.2fr_0.8fr_1fr] sm:gap-12"
    >
      {/* brand + tagline */}
      <div class="max-w-xs">
        <Wordmark class="text-2xl" />
        <p class="mt-3 text-sm leading-relaxed text-steel">
          Microsoft 365, websites, domains, backup and practical advice — handled
          by one accountable operator.
        </p>
      </div>

      {/* nav */}
      <nav aria-label="Footer" class="flex flex-col gap-2.5">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="text-sm text-steel transition-colors hover:text-ink"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      {/* legal */}
      <div class="sm:text-right">
        <p class="text-sm leading-relaxed text-steel">
          Support is business hours, with best-effort out of hours.
        </p>
        <p class="mt-4 font-mono text-xs text-steel">© {year} TWNY Pty Ltd</p>
      </div>
    </div>
  </div>
</footer>
