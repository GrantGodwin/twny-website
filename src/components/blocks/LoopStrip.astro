---
// The operating loop as a refined, well-spaced editorial sequence — oversized
// index numerals down the margin, generous rhythm. Not an icon strip (CD §13).
import { loop } from "../../data/loop";
---

<section class="bg-sand">
  <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 sm:py-28">
    <div class="max-w-2xl">
      <p
        data-animate
        class="font-mono text-xs uppercase tracking-[0.18em] text-mineral mb-5"
      >
        How we work
      </p>
      <h2
        data-animate
        class="font-display text-3xl font-semibold leading-[1.1] text-ink text-balance sm:text-4xl lg:text-5xl"
      >
        One operating loop, every time.
      </h2>
      <p data-animate class="mt-6 text-steel leading-relaxed text-pretty">
        The same six steps run every engagement. It's how the work stays
        predictable and the price stays honest.
      </p>
    </div>

    <ol class="mt-16 border-t border-line">
      {
        loop.map((step, i) => (
          <li
            data-animate
            class="grid items-baseline gap-2 border-b border-line py-8 sm:grid-cols-[5rem_minmax(0,14rem)_1fr] sm:gap-10 sm:py-9"
          >
            <span class="font-mono text-2xl text-mineral tabular-nums sm:text-3xl">
              {String(i + 1).padStart(2, "0")}
            </span>
            <h3 class="font-display text-xl font-semibold text-ink sm:text-2xl">
              {step.name}
            </h3>
            <p class="max-w-xl text-steel leading-relaxed text-pretty">
              {step.blurb}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
