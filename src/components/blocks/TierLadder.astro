---
// Four-tier ladder with toggle-bound prices. Plain cards, not glossy.
import { tiers, priceFaces } from "../../data/productivity";
import Price from "../ui/Price.astro";
import Button from "../ui/Button.astro";
---

<div class="grid gap-px bg-line border border-line rounded-sm overflow-hidden sm:grid-cols-2 lg:grid-cols-4">
  {
    tiers.map((tier) => {
      const faces = priceFaces(tier);
      return (
        <div class="bg-paper p-6 flex flex-col">
          <h3 class="font-display font-semibold text-ink">{tier.name}</h3>
          <p class="mt-1.5 text-sm text-steel leading-relaxed min-h-[2.5rem]">
            {tier.who}
          </p>
          <div class="mt-4">
            <Price
              monthly={faces.monthly}
              annualTotal={faces.annualTotal}
              effectiveMonthly={faces.effectiveMonthly}
            />
          </div>
          {tier.interpolated && (
            <p class="mt-2 font-mono text-[0.7rem] text-ember leading-tight">
              ▲ Interpolated — not in the Atlas model.
            </p>
          )}
          <div class="mt-5 pt-4 border-t border-line">
            <Button href="/contact" variant="mineral" class="text-sm">
              Talk to us
            </Button>
          </div>
        </div>
      );
    })
  }
</div>
