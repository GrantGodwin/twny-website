---
// Closing CTA. Low-pressure "point" — single Ember decision.
import Button from "../ui/Button.astro";

interface Props {
  heading?: string;
  sub?: string;
}
const {
  heading = "Tell us what you need; we'll recommend a starting point.",
  sub = "No pressure, no sales funnel. A short conversation, then a clear recommendation.",
} = Astro.props;
---

<section class="bg-band border-y border-line">
  <div class="mx-auto max-w-6xl px-5 sm:px-8 py-16 sm:py-20">
    <div class="max-w-2xl">
      <h2 class="font-display text-2xl sm:text-3xl font-semibold text-ink text-balance">
        {heading}
      </h2>
      <p class="mt-3 text-steel leading-relaxed">{sub}</p>
      <div class="mt-7">
        <Button href="/contact" variant="ember">Tell us what you need</Button>
      </div>
    </div>
  </div>
</section>
