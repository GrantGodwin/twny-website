---
// The offer as one coherent operation, not a menu. A lead statement sets the
// "one managed tenancy" idea; the two clusters read as editorial columns
// divided by a hairline; consulting sits beside as a quiet aside (CD §5, §10).
import { clusters, consultingAside } from "../../data/offer";
---

<section class="bg-paper border-y border-line">
  <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 sm:py-28">
    <div class="max-w-3xl">
      <p
        data-animate
        class="font-mono text-xs uppercase tracking-[0.18em] text-mineral mb-5"
      >
        The offer
      </p>
      <h2
        data-animate
        class="font-display text-3xl font-semibold leading-[1.1] text-ink text-balance sm:text-4xl lg:text-5xl"
      >
        One managed tenancy — not four disconnected services.
      </h2>
      <p
        data-animate
        class="mt-6 text-lg text-steel leading-relaxed text-pretty"
      >
        Everything sits on one tenant we own and look after: your email, files,
        identity, backup, domain and, where it applies, the website — one source
        of truth, and clean ownership you can always take with you.
      </p>
    </div>

    <div class="mt-16 grid gap-px overflow-hidden border-y border-line bg-line sm:grid-cols-2">
      {
        clusters.map((cluster) => (
          <div data-animate class="bg-paper py-9 sm:px-9 sm:py-10">
            <h3 class="font-display text-xl font-semibold text-ink sm:text-2xl">
              {cluster.title}
            </h3>
            <p class="mt-3 max-w-md text-steel leading-relaxed text-pretty">
              {cluster.blurb}
            </p>
            <ul class="mt-6 space-y-3">
              {cluster.items.map((item) => (
                <li class="flex items-start gap-3 text-ink">
                  <span
                    class="mt-2.5 size-1.5 shrink-0 rounded-full bg-mineral"
                    aria-hidden="true"
                  />
                  <span class="leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <p data-animate class="mt-10 max-w-2xl text-steel leading-relaxed text-pretty">
      <span class="font-display font-medium text-ink">{consultingAside.title}.</span>{" "}
      {consultingAside.blurb}
    </p>
  </div>
</section>
