---
// What we run vs what sits outside. Boundaries are content.
import { includedExcluded } from "../../data/productivity";
---

<div class="grid gap-6 md:grid-cols-2">
  <div class="bg-paper border border-line rounded-sm p-6 sm:p-7">
    <h3 class="font-display font-semibold text-ink">What we run</h3>
    <ul class="mt-4 space-y-2.5">
      {
        includedExcluded.included.map((item) => (
          <li class="flex items-start gap-2.5 text-ink">
            <span class="text-mineral mt-0.5" aria-hidden="true">✓</span>
            <span class="leading-relaxed">{item}</span>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="bg-paper border border-line rounded-sm p-6 sm:p-7">
    <h3 class="font-display font-semibold text-ink">What sits outside</h3>
    <ul class="mt-4 space-y-2.5">
      {
        includedExcluded.excluded.map((item) => (
          <li class="flex items-start gap-2.5 text-steel">
            <span class="mt-0.5" aria-hidden="true">—</span>
            <span class="leading-relaxed">{item}</span>
          </li>
        ))
      }
    </ul>
  </div>
</div>
