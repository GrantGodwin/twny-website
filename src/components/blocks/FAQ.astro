---
// Pricing FAQ — pre-empts objections. Native <details>, no JS, restrained.
import { faqs } from "../../data/pricing";
---

<div class="border border-line rounded-sm divide-y divide-line overflow-hidden">
  {
    faqs.map((item) => (
      <details class="group bg-paper">
        <summary class="flex items-center justify-between gap-4 cursor-pointer list-none p-5 font-display font-medium text-ink hover:text-mineral transition-colors">
          {item.q}
          <span
            class="text-steel font-mono transition-transform group-open:rotate-45"
            aria-hidden="true"
          >
            +
          </span>
        </summary>
        <p class="px-5 pb-5 -mt-1 text-steel leading-relaxed max-w-2xl">
          {item.a}
        </p>
      </details>
    ))
  }
</div>
