---
// "What you actually get" — surface (left) -> underlying need (right).
import { surfaceNeeds } from "../../data/offer";
---

<ul class="border-t border-line">
  {
    surfaceNeeds.map((pair) => (
      <li class="grid sm:grid-cols-[minmax(0,14rem)_1fr] gap-1 sm:gap-8 py-5 border-b border-line">
        <span class="font-display font-medium text-ink">{pair.surface}</span>
        <span class="text-steel leading-relaxed text-pretty">
          {pair.need}
        </span>
      </li>
    ))
  }
</ul>
