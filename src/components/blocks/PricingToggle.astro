---
// Annual Commitment / Monthly Flex switch. Flips <html data-billing>;
// Price components react via CSS. Default is annual (set on <html>).
---

<div
  class="inline-flex items-center rounded-sm border border-line bg-paper p-1 font-mono text-sm"
  role="group"
  aria-label="Billing mode"
>
  <button
    type="button"
    data-billing-set="annual"
    class="billing-btn px-3 py-1.5 rounded-sm transition-colors"
  >
    Annual commitment
  </button>
  <button
    type="button"
    data-billing-set="monthly"
    class="billing-btn px-3 py-1.5 rounded-sm transition-colors"
  >
    Monthly flex
  </button>
</div>

<style>
  /* Active face styled from the document state, so it is correct on load. */
  :global(html[data-billing="annual"]) .billing-btn[data-billing-set="annual"],
  :global(html[data-billing="monthly"]) .billing-btn[data-billing-set="monthly"] {
    background-color: var(--mineral);
    color: #fff;
  }
  .billing-btn {
    color: var(--steel);
  }
</style>

<script>
  document.querySelectorAll("[data-billing-set]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const mode = btn.getAttribute("data-billing-set");
      if (mode) document.documentElement.setAttribute("data-billing", mode);
    });
  });
</script>
