---
// Closing invitation — conversation, not funnel. One Ember decision, framed as
// a human exchange, surrounded by space. No urgency, no pop-ups (CD §13, §17).
import Button from "../ui/Button.astro";
---

<section class="bg-sand">
  <div class="mx-auto max-w-6xl px-5 sm:px-8 py-24 sm:py-32">
    <div class="max-w-3xl">
      <p
        data-animate
        class="font-mono text-xs uppercase tracking-[0.18em] text-mineral mb-5"
      >
        What happens next
      </p>
      <h2
        data-animate
        class="font-display text-3xl font-semibold leading-[1.08] text-ink text-balance sm:text-5xl"
      >
        Tell us what you need; we'll recommend a starting point.
      </h2>
      <p
        data-animate
        class="mt-6 max-w-xl text-lg text-steel leading-relaxed text-pretty"
      >
        A short conversation, then a clear recommendation — nothing you don't
        need. No sales funnel, no pressure.
      </p>
      <div data-animate class="mt-10 flex flex-wrap items-center gap-x-7 gap-y-3">
        <Button href="/contact" variant="ember">Start a conversation</Button>
        <a
          href="/pricing"
          class="font-body text-sm text-steel underline-offset-4 transition-colors hover:text-ink hover:underline"
        >
          Or see pricing first
        </a>
      </div>
    </div>
  </div>
</section>
