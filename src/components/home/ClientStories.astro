---
// "Helping businesses like yours" — a living, cinematic client-stories feature
// (the former "Social proof" item). Architecture (do not redesign): a large
// rounded image with the copy overlaid on the left, a client selector across
// the bottom, auto-rotating stories with a slow cross-dissolve.
//
// Overlay hierarchy: company (anchors the story) → quote (hero) → person +
// role → outcome → divider → services. The business type lives in the
// selector, not the overlay.
//
// Graceful degradation: the first story + roster render server-side, so the
// section is complete with JS disabled. Reduced motion disables rotation and the
// cross-dissolve; manual selection still swaps instantly.
import { stories } from "../../data/offer";
import ServiceIcon from "./ServiceIcon.astro";
import Button from "../ui/Button.astro";

const first = stories[0];
---

<section
  id="businesses-like-yours"
  data-client-stories
  class="bg-sand text-ink"
  aria-roledescription="Featured client stories"
>
  <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 lg:py-28">
    <div data-animate class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-steel">
        Client stories
      </p>
      <h2 class="mt-6 font-display text-3xl font-semibold leading-[1.07] text-balance sm:text-4xl">
        Helping businesses like yours.
      </h2>
      <p class="mt-5 max-w-xl text-sm leading-relaxed text-steel text-pretty">
        Real businesses we look after — and what changes when the technology is
        simply handled.
      </p>
    </div>

    {/* DESKTOP (lg+) — the cinematic feature: image is the canvas; copy
        overlaid in the left negative space; journey indicator + roster below.
        Below lg, this entire block is hidden in favour of the vertical
        swipeable cards below — see MOBILE/TABLET. */}
    <div data-cs-desktop class="hidden lg:block">
    {/* FEATURE — image is the canvas; copy overlaid in the left negative space.
        Content (relative, in-flow) drives the height so it never clips; the
        image (absolute) fills behind it. */}
    <div
      data-animate
      class="cs-feature relative isolate flex flex-col overflow-hidden rounded-xl bg-band min-h-[31rem] sm:min-h-[34rem] lg:min-h-[34rem] xl:min-h-[38rem] mt-10 lg:mt-14"
      aria-label="Featured client story"
    >
      <div class="cs-media absolute inset-0 -z-10">
        <img
          data-cs-img-a
          src={first.image}
          alt={first.imageAlt}
          loading="lazy"
          decoding="async"
          class="cs-layer is-front"
        />
        <img
          data-cs-img-b
          alt=""
          aria-hidden="true"
          decoding="async"
          class="cs-layer"
        />
        <div class="cs-scrim absolute inset-0" aria-hidden="true"></div>
      </div>

      <div
        data-cs-content
        class="cs-content relative z-10 flex w-full flex-1 flex-col justify-end p-6 sm:p-10 lg:max-w-[26rem] lg:justify-between lg:p-0 lg:pt-12 lg:pb-[17px] lg:pl-8 xl:pt-16 xl:pb-[25px] xl:pl-10"
      >
        {/* TOP — company (anchors the story before the quote), then the quote
            (hero) in a fixed-height well so the name always lands at the same
            level whether the quote runs two or three lines, then the person
            and their role */}
        <div class="cs-top">
          <p data-cs-company class="cs-company-label">{first.name}</p>

          <div class="cs-quote-wrap mt-4 lg:mt-5">
            <blockquote
              class="cs-quote font-display text-xl italic font-medium leading-[1.16] text-white text-pretty sm:text-2xl lg:text-[2.2rem]"
            >
              <span class="cs-quote__mark" aria-hidden="true">“</span><span
                data-cs-quote>{first.quote}</span
              ><span class="cs-quote__mark" aria-hidden="true">”</span>
            </blockquote>
          </div>

          <p data-cs-person class="cs-person mt-7 lg:mt-8 text-xl lg:text-2xl">
            {first.person}
          </p>
          <p data-cs-role class="cs-role mt-1 text-base">{first.role}</p>
        </div>

        {/* BOTTOM — outcome (closing line), a full-width fade divider, then the
            services (icon with label beside) beneath it */}
        <div class="cs-bottom mt-10 lg:mt-0">
          <p
            data-cs-outcome
            class="max-w-md font-body text-lg font-medium leading-snug text-white text-pretty sm:text-xl"
          >
            {first.outcome}
          </p>

          <div class="cs-divider mt-6" aria-hidden="true"></div>

          <div data-cs-looked class="mt-6">
            {
              stories.map((s, i) => (
                <ul class="cs-looked" data-looked-idx={i} hidden={i !== 0}>
                  {s.lookedAfter.map((item) => (
                    <li class="cs-looked__item">
                      <ServiceIcon name={item} />
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    {/* JOURNEY — a segmented progression indicator between the card and the
        selector: a thin Steel line, one node per client (aligned with the
        roster's columns at lg), and a Mineral "fuse" that burns from the
        active node to the next over the 5s dwell. Communicates progression
        through the stories, not time remaining. No labels, no countdown. */}
    <div data-animate class="mt-8 lg:mt-10">
      <div class="cs-journey" aria-hidden="true">
        <div class="cs-journey__track"></div>
        <div class="cs-journey__fuse" data-cs-fuse></div>
        <div class="cs-journey__fuse" data-cs-fuse-2></div>
        <div class="cs-journey__row">
          {
            stories.map((_s, i) => (
              <span
                class:list={["cs-journey__node", i === 0 && "is-active"]}
                data-cs-node
                data-index={i}
              />
            ))
          }
        </div>
      </div>
    </div>

    {/* ROSTER — the client selector; company over business type. The only
        navigation. */}
    <ul class="cs-roster mt-3 grid grid-cols-2 gap-x-6 gap-y-6 sm:grid-cols-3 lg:grid-cols-5">
      {
        stories.map((s, i) => (
          <li>
            <button
              type="button"
              data-cs-roster
              data-index={i}
              aria-pressed={i === 0 ? "true" : "false"}
              aria-controls="businesses-like-yours"
              class="cs-roster__item w-full text-center"
            >
              <span class="cs-roster__name block font-display text-base font-semibold leading-snug text-pretty sm:text-lg">
                {s.name}
              </span>
              <span class="cs-roster__type mt-1 block text-xs leading-snug text-pretty">
                {s.type}
              </span>
            </button>
          </li>
        ))
      }
    </ul>

    {/* Primary conversion CTA — Ember, matching every other primary CTA. */}
    <div data-animate class="mt-[26px] lg:mt-[34px]">
      <Button href="/contact" variant="ember">
        Let’s talk about your business
      </Button>
    </div>
    </div>

    {/* MOBILE/TABLET (below lg) — one vertical card per client, swiped through
        (native scroll-snap) or paged with arrows (tablet, sm+), with dots
        showing position. Replaces the desktop's roster + journey indicator,
        which don't fit a one-card-at-a-time pattern. Same overlay content and
        hierarchy as the desktop card (company → quote → person + role →
        outcome → divider → services), just one story per card instead of one
        story rotating through a shared frame. */}
    <div data-cs-mobile class="lg:hidden mt-10">
      <div class="cm-wrap relative">
        <div class="cm-track" data-cm-track>
          {
            stories.map((s, i) => (
              <div class="cm-slide relative isolate flex flex-col overflow-hidden rounded-xl bg-band" data-cm-slide>
                <img
                  src={s.image}
                  alt={s.imageAlt}
                  loading={i === 0 ? "eager" : "lazy"}
                  decoding="async"
                  class="absolute inset-0 h-full w-full object-cover"
                />
                <div class="cs-scrim absolute inset-0" aria-hidden="true"></div>

                <div class="relative z-10 flex h-full w-full flex-col justify-end p-6 sm:p-8">
                  <p class="cs-company-label">{s.name}</p>

                  <blockquote class="cs-quote mt-4 font-display text-2xl italic font-medium leading-[1.18] text-white text-pretty">
                    <span class="cs-quote__mark" aria-hidden="true">“</span>
                    {s.quote}
                    <span class="cs-quote__mark" aria-hidden="true">”</span>
                  </blockquote>

                  <p class="cs-person mt-6 text-xl">{s.person}</p>
                  <p class="cs-role mt-1 text-base">{s.role}</p>

                  <p class="mt-6 max-w-md font-body text-lg font-medium leading-snug text-white text-pretty">
                    {s.outcome}
                  </p>

                  <div class="cs-divider mt-5" aria-hidden="true"></div>

                  <ul class="cs-looked mt-5">
                    {s.lookedAfter.map((item) => (
                      <li class="cs-looked__item">
                        <ServiceIcon name={item} />
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ))
          }
        </div>

        {/* Arrows — tablet only (sm and up, hidden on phone where swipe is the
            natural gesture; the whole block disappears at lg anyway). */}
        <button
          type="button"
          data-cm-prev
          aria-label="Previous client"
          class="cm-arrow cm-arrow--prev hidden sm:flex"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
            <path d="M15 18l-6-6 6-6" />
          </svg>
        </button>
        <button
          type="button"
          data-cm-next
          aria-label="Next client"
          class="cm-arrow cm-arrow--next hidden sm:flex"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
            <path d="M9 18l6-6-6-6" />
          </svg>
        </button>
      </div>

      {/* Dots — the only indicator of how many clients there are and which is
          showing; doubles as direct navigation. */}
      <div class="cm-dots mt-5" data-cm-dots role="tablist" aria-label="Client stories">
        {
          stories.map((s, i) => (
            <button
              type="button"
              data-cm-dot
              aria-label={`Go to ${s.name}`}
              aria-current={i === 0 ? "true" : "false"}
              class="cm-dot"
            />
          ))
        }
      </div>

      <div data-animate class="mt-[26px]">
        <Button href="/contact" variant="ember">
          Let’s talk about your business
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  /* Feature card — a faint, true 1px Steel border plus a very soft, large-blur
     shadow. Just enough to lift it off the page; not a floating SaaS card. */
  .cs-feature {
    border: 1px solid color-mix(in srgb, var(--steel) 12%, transparent);
    box-shadow: 0 70px 130px -50px rgba(0, 0, 0, 0.45);
  }

  /* Crossfade layers — two stacked images; only the front is visible. Slow cross
     dissolve, no slide, no scale. */
  .cs-layer {
    position: absolute;
    inset: 0;
    height: 100%;
    width: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1000ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .cs-layer.is-front {
    opacity: 1;
  }

  /* Scrim — a strong LEFT gradient on desktop (the right ~28% stays rich for the
     photo subject); a contained bottom gradient below lg where copy sits lower.
     Never darkens the whole image. */
  .cs-scrim {
    background-image: linear-gradient(
      to top,
      rgba(10, 13, 17, 0.95) 0%,
      rgba(10, 13, 17, 0.85) 42%,
      rgba(10, 13, 17, 0.5) 66%,
      rgba(10, 13, 17, 0.16) 86%,
      rgba(10, 13, 17, 0) 100%
    );
  }
  @media (min-width: 1024px) {
    /* Dark behind the text on the left, feathered with many close stops so the
       falloff is invisible — it simply dissolves into the image. Zero-alpha
       sand (not `transparent`) keeps the fade from muddying toward black. */
    .cs-scrim {
      background-image: linear-gradient(
        90deg,
        rgba(10, 13, 17, 0.95) 0%,
        rgba(10, 13, 17, 0.94) 32%,
        rgba(10, 13, 17, 0.82) 50%,
        rgba(10, 13, 17, 0.58) 64%,
        rgba(10, 13, 17, 0.3) 78%,
        rgba(10, 13, 17, 0) 92%
      );
    }
  }

  /* Business name — anchors the story before the quote. Mineral, refined but
     present: a step up in size and weight from a quiet kicker label. */
  .cs-company-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--mineral);
  }

  /* Quote well — reserves room for up to three lines and bottom-aligns the
     quote, so the person/role beneath always sit at the same vertical height
     regardless of the quote's length. */
  .cs-quote-wrap {
    display: flex;
    align-items: flex-end;
    min-height: 4.4rem;
  }
  @media (min-width: 640px) {
    .cs-quote-wrap {
      min-height: 5.4rem;
    }
  }
  @media (min-width: 1024px) {
    .cs-quote-wrap {
      min-height: 7.7rem;
    }
  }

  /* Quote marks — subtle, Mineral; never oversized. */
  .cs-quote__mark {
    color: var(--mineral);
  }

  /* Person (Inter SemiBold White) over their role + company (Inter Regular,
     Steel). */
  .cs-person {
    font-family: var(--font-body);
    font-weight: 600;
    color: #fff;
  }
  .cs-role {
    font-family: var(--font-body);
    font-weight: 400;
    color: var(--steel);
  }

  /* Content fade on swap — copy settles quickly while the image keeps
     dissolving behind it. */
  .cs-content {
    transition: opacity 300ms ease;
  }
  .cs-content.is-swapping {
    opacity: 0;
  }

  /* Full-width fade divider — consistent with the homepage divider language
     (transparent → solid middle → transparent). */
  .cs-divider {
    height: 1px;
    width: 100%;
    background: linear-gradient(
      to right,
      transparent,
      rgba(255, 255, 255, 0.3) 28%,
      rgba(255, 255, 255, 0.3) 72%,
      transparent
    );
  }

  /* Services — three across (room for up to six over two rows); icon with a
     short label beside it; Inter Regular, small, Steel; one consistent outline
     icon family; a service never wraps. */
  .cs-looked {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem 1.25rem;
  }
  .cs-looked[hidden] {
    display: none;
  }
  .cs-looked__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
    font-size: 0.82rem;
    font-weight: 400;
    white-space: nowrap;
    color: var(--steel);
  }
  /* Icons read in Mineral; the labels stay Steel. */
  .cs-looked__item :global(svg) {
    flex-shrink: 0;
    color: var(--mineral);
  }

  /* Journey indicator — a thin Steel line spanning almost the full width, with
     one node per client. Nodes sit in a 5-column grid matching the roster's
     lg:grid-cols-5, so each lands directly above its client at that
     breakpoint. A Mineral "fuse" travels the track in three phases that loop
     continuously: node→node (normal dwell), last node→right edge (the final
     client's dwell), then left edge→first node (the loop's re-entry) — never
     simply stopping at the last node. Duration varies per phase via inline
     style; only the timing function/fill come from the class. */
  .cs-journey {
    position: relative;
    height: 1.25rem;
    display: flex;
    align-items: center;
  }
  .cs-journey__track {
    position: absolute;
    left: 2%;
    right: 2%;
    top: 50%;
    height: 1px;
    background-color: color-mix(in srgb, var(--steel) 32%, transparent);
    transform: translateY(-50%);
  }
  .cs-journey__fuse {
    position: absolute;
    top: 50%;
    left: 0%;
    height: 2px;
    width: 20%;
    transform: translateY(-50%) scaleX(0);
    transform-origin: left center;
    background-color: var(--mineral);
  }
  .cs-journey__fuse.is-burning {
    animation-name: cs-fuse;
    animation-duration: 5000ms;
    animation-timing-function: linear;
    animation-fill-mode: forwards;
  }
  @keyframes cs-fuse {
    from {
      transform: translateY(-50%) scaleX(0);
    }
    to {
      transform: translateY(-50%) scaleX(1);
    }
  }
  [data-client-stories].is-paused .cs-journey__fuse.is-burning {
    animation-play-state: paused;
  }
  .cs-journey__row {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    width: 100%;
  }
  .cs-journey__node {
    justify-self: center;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--steel);
    transition: background-color 220ms ease, transform 220ms ease;
  }
  .cs-journey__node.is-active {
    background-color: var(--mineral);
    transform: scale(1.25);
  }

  /* Roster — active: company and industry both white (no Mineral here — the
     journey indicator already owns Mineral). Inactive: company plain Steel,
     industry a touch darker than Steel. Hover brightens the company only; no
     movement or scaling. */
  .cs-roster__item {
    cursor: pointer;
  }
  .cs-roster__name {
    color: var(--steel);
    transition: color 220ms ease;
  }
  .cs-roster__type {
    color: color-mix(in srgb, var(--steel) 65%, var(--sand) 35%);
    transition: color 220ms ease;
  }
  .cs-roster__item:hover .cs-roster__name,
  .cs-roster__item:focus-visible .cs-roster__name {
    color: var(--ink);
  }
  .cs-roster__item[aria-pressed="true"] .cs-roster__name,
  .cs-roster__item[aria-pressed="true"] .cs-roster__type {
    color: var(--ink);
  }

  @media (prefers-reduced-motion: reduce) {
    .cs-layer,
    .cs-content,
    .cs-roster__name,
    .cs-roster__type {
      transition: none;
    }
    .cs-journey {
      display: none;
    }
  }

  /* MOBILE/TABLET carousel — one vertical card per client. Native horizontal
     scroll-snap drives swipe; arrows and dots are equivalent, fully keyboard-
     operable controls, not just a touch affordance. */
  .cm-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .cm-track::-webkit-scrollbar {
    display: none;
  }
  .cm-slide {
    flex: 0 0 100%;
    scroll-snap-align: center;
    height: 90vh;
    max-height: 760px;
    min-height: 30rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .cm-track {
      scroll-behavior: auto;
    }
  }

  /* Arrows — a quiet circular control over the image, tablet only (sm+); the
     whole carousel is hidden at lg in favour of the desktop feature. */
  .cm-arrow {
    position: absolute;
    top: 50%;
    z-index: 20;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background-color: rgba(10, 13, 17, 0.55);
    color: #fff;
    transform: translateY(-50%);
    transition: background-color 200ms ease;
  }
  .cm-arrow:hover,
  .cm-arrow:focus-visible {
    background-color: rgba(10, 13, 17, 0.78);
  }
  .cm-arrow--prev {
    left: 0.75rem;
  }
  .cm-arrow--next {
    right: 0.75rem;
  }

  /* Dots — Mineral when active, dim Steel otherwise; the only count/position
     indicator. */
  .cm-dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  .cm-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--steel);
    opacity: 0.5;
    transition: background-color 200ms ease, opacity 200ms ease, transform 200ms ease;
  }
  .cm-dot[aria-current="true"] {
    background-color: var(--mineral);
    opacity: 1;
    transform: scale(1.35);
  }
</style>

<script>
  import { stories } from "../../data/offer";

  const root = document.querySelector<HTMLElement>("[data-client-stories]");
  if (root) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isTouch = window.matchMedia("(hover: none) and (pointer: coarse)").matches;
    const imgA = root.querySelector<HTMLImageElement>("[data-cs-img-a]");
    const imgB = root.querySelector<HTMLImageElement>("[data-cs-img-b]");
    const content = root.querySelector<HTMLElement>("[data-cs-content]");
    const companyEl = root.querySelector<HTMLElement>("[data-cs-company]");
    const quoteEl = root.querySelector<HTMLElement>("[data-cs-quote]");
    const personEl = root.querySelector<HTMLElement>("[data-cs-person]");
    const roleEl = root.querySelector<HTMLElement>("[data-cs-role]");
    const outcomeEl = root.querySelector<HTMLElement>("[data-cs-outcome]");
    const lookedLists = Array.from(
      root.querySelectorAll<HTMLElement>("[data-looked-idx]")
    );
    const fuse = root.querySelector<HTMLElement>("[data-cs-fuse]");
    const fuseEntrance = root.querySelector<HTMLElement>("[data-cs-fuse-2]");
    const nodes = Array.from(
      root.querySelectorAll<HTMLElement>("[data-cs-node]")
    );
    const rosterItems = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-cs-roster]")
    );

    const SWAP_DELAY = 280;
    let front: HTMLImageElement | null = imgA;
    let active = 0;
    let paused = false;
    let offscreen = false;
    let stopped = false; // touch: auto-rotation ends after first manual tap

    const syncPlayState = () => {
      root.classList.toggle("is-paused", paused || offscreen);
    };

    const setContent = (i: number) => {
      const s = stories[i];
      if (companyEl) companyEl.textContent = s.name;
      if (quoteEl) quoteEl.textContent = s.quote;
      if (personEl) personEl.textContent = s.person;
      if (roleEl) roleEl.textContent = s.role;
      if (outcomeEl) outcomeEl.textContent = s.outcome;
      lookedLists.forEach((ul, idx) => (ul.hidden = idx !== i));
    };

    const swapImage = (s: (typeof stories)[number]) => {
      if (!imgA || !imgB || !front) return;
      const back = front === imgA ? imgB : imgA;
      const show = () => {
        if (!front) return;
        back.alt = s.imageAlt;
        back.removeAttribute("aria-hidden");
        back.classList.add("is-front");
        front.alt = "";
        front.setAttribute("aria-hidden", "true");
        front.classList.remove("is-front");
        front = back;
      };
      if (back.getAttribute("src") === s.image) {
        show();
        return;
      }
      back.onload = show;
      back.onerror = show;
      back.src = s.image;
    };

    // Node centres sit at the middle of each of the 5 grid columns: 10%, 30%,
    // 50%, 70%, 90%, within a track inset 2%–98%. A normal segment (node i ->
    // node i+1) is a fixed 20% wide, starting at 10 + i*20.
    const LAST = stories.length - 1;
    const segmentLeft = (i: number) => 10 + i * 20;

    const updateNodes = (i: number) => {
      nodes.forEach((n, idx) => n.classList.toggle("is-active", idx === i));
    };

    // Three fuse phases, looping continuously rather than stopping at the last
    // node: "segment" (node -> next node, normal dwell), "tail" (last node ->
    // the track's right edge, the final client's dwell), and "entrance" (the
    // track's left edge -> the first node, a quick re-entry before the loop's
    // first normal segment resumes). Duration varies per phase; the CSS class
    // supplies only the easing/fill.
    let fuseMode: "segment" | "tail" | "entrance" = "segment";

    const paintFuse = (
      el: HTMLElement | null,
      left: number,
      width: number,
      durationMs: number
    ) => {
      if (!el) return;
      el.classList.remove("is-burning");
      el.style.animation = "none";
      el.style.left = `${left}%`;
      el.style.width = `${width}%`;
      el.style.animationDuration = `${durationMs}ms`;
    };

    const burnFuse = (el: HTMLElement | null) => {
      if (!el || stopped || reduce) return;
      void root.offsetWidth; // reflow so the animation restarts cleanly
      el.style.animation = "";
      el.classList.add("is-burning");
    };

    // Fully clears a fuse element back to its inactive (unlit) state.
    const clearFuse = (el: HTMLElement | null) => {
      if (!el) return;
      el.classList.remove("is-burning");
      el.style.animation = "none";
    };

    const startSegmentFuse = (i: number) => {
      fuseMode = "segment";
      clearFuse(fuseEntrance); // hide the entrance fuse; only used during the wrap
      paintFuse(fuse, segmentLeft(i), 20, 5000);
      burnFuse(fuse);
    };
    // The final client's dwell is split evenly: 2s for the line to reach the
    // right edge, then 2s for the entrance fuse to fill in from the left edge
    // to the first node. The tail fuse is left lit (not reset) while the
    // entrance fuse runs, so the line is illuminated on both the right and
    // left simultaneously until the moment it reaches the first node — that's
    // when the story actually switches.
    const startTailFuse = () => {
      fuseMode = "tail";
      clearFuse(fuseEntrance);
      paintFuse(fuse, 90, 8, 2000); // last node (90%) to the track's right edge (98%)
      burnFuse(fuse);
    };
    const startEntranceFuse = () => {
      fuseMode = "entrance";
      paintFuse(fuseEntrance, 2, 8, 2000); // left edge (2%) into the first node (10%)
      if (stopped || reduce) {
        // Motion disabled / stopped: land directly on the first client's
        // normal segment rather than skipping the loop silently.
        switchTo(0, true);
        startSegmentFuse(0);
        return;
      }
      burnFuse(fuseEntrance);
    };

    // Switches the visible story (content, image, roster, nodes) without
    // touching the fuse — callers decide which phase to start next.
    const switchTo = (i: number, animate: boolean) => {
      if (animate && !reduce && content) {
        content.classList.add("is-swapping");
        window.setTimeout(() => {
          setContent(i);
          content.classList.remove("is-swapping");
        }, SWAP_DELAY);
      } else {
        setContent(i);
      }
      swapImage(stories[i]);
      rosterItems.forEach((b, idx) =>
        b.setAttribute("aria-pressed", String(idx === i))
      );
      active = i;
      updateNodes(i);
    };

    // Used by the roster (hover/focus/click) and reduced-motion fallbacks:
    // switch directly to a story and start its ordinary segment/tail fuse.
    const render = (i: number, animate: boolean) => {
      switchTo(i, animate);
      if (i === LAST) startTailFuse();
      else startSegmentFuse(i);
    };

    // Preload so crossfades don't flash.
    for (const s of stories) {
      const im = new Image();
      im.src = s.image;
    }

    // The primary fuse only ever fires for "segment" and "tail" phases — the
    // tail intentionally stays lit afterwards (startEntranceFuse below never
    // clears it), so reaching the right edge starts the entrance fuse without
    // switching the story yet.
    fuse?.addEventListener("animationend", () => {
      if (paused || offscreen || stopped) return;
      if (fuseMode === "tail") {
        startEntranceFuse();
      } else if (fuseMode === "segment") {
        switchTo(active + 1, true);
        if (active === LAST) startTailFuse();
        else startSegmentFuse(active);
      }
    });

    // The entrance fuse fires only when the wrap's left-edge fill reaches the
    // first node — that is the moment the story actually switches.
    fuseEntrance?.addEventListener("animationend", () => {
      if (paused || offscreen || stopped) return;
      if (fuseMode === "entrance") {
        switchTo(0, true);
        startSegmentFuse(0);
      }
    });

    rosterItems.forEach((b, idx) => {
      const activate = () => {
        if (idx !== active) render(idx, true);
      };
      b.addEventListener("mouseenter", activate);
      b.addEventListener("focus", activate);
      b.addEventListener("click", () => {
        // Touch: a manual tap ends auto-rotation for the session.
        if (isTouch) stopped = true;
        activate();
      });
    });

    // Pause only when hovering the image card or a client name in the roster —
    // not merely being near the section.
    const feature = root.querySelector<HTMLElement>(".cs-feature");
    const roster = root.querySelector<HTMLElement>(".cs-roster");
    let hoverFeature = false;
    let hoverRoster = false;
    const updatePause = () => {
      paused = hoverFeature || hoverRoster;
      syncPlayState();
    };
    feature?.addEventListener("mouseenter", () => {
      hoverFeature = true;
      updatePause();
    });
    feature?.addEventListener("mouseleave", () => {
      hoverFeature = false;
      updatePause();
    });
    roster?.addEventListener("mouseenter", () => {
      hoverRoster = true;
      updatePause();
    });
    roster?.addEventListener("mouseleave", () => {
      hoverRoster = false;
      updatePause();
    });
    roster?.addEventListener("focusin", () => {
      hoverRoster = true;
      updatePause();
    });
    roster?.addEventListener("focusout", () => {
      hoverRoster = false;
      updatePause();
    });

    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) offscreen = !e.isIntersecting;
          syncPlayState();
        },
        { threshold: 0.25 }
      );
      io.observe(root);
    }

    // Kick off: light the first node and start its normal segment fuse
    // (already server-rendered as the active story).
    updateNodes(0);
    startSegmentFuse(0);
  }
</script>

<script>
  // MOBILE/TABLET carousel — each story is a fully static, pre-rendered slide
  // (no content-swapping JS needed, unlike the desktop feature). This script
  // only keeps the dots in sync with scroll position and wires the arrows; no
  // auto-rotation — a touch carousel that advances on its own while someone is
  // mid-swipe is exactly the surprising behaviour to avoid.
  const mobileRoot = document.querySelector<HTMLElement>("[data-cs-mobile]");
  if (mobileRoot) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const track = mobileRoot.querySelector<HTMLElement>("[data-cm-track]");
    const slides = Array.from(
      mobileRoot.querySelectorAll<HTMLElement>("[data-cm-slide]")
    );
    const dots = Array.from(
      mobileRoot.querySelectorAll<HTMLButtonElement>("[data-cm-dot]")
    );
    const prevBtn = mobileRoot.querySelector<HTMLButtonElement>("[data-cm-prev]");
    const nextBtn = mobileRoot.querySelector<HTMLButtonElement>("[data-cm-next]");

    let current = 0;
    let rafId = 0;

    const setActive = (i: number) => {
      current = i;
      dots.forEach((d, idx) =>
        d.setAttribute("aria-current", String(idx === i))
      );
    };

    const goTo = (i: number) => {
      if (!track || !slides.length) return;
      const idx = ((i % slides.length) + slides.length) % slides.length;
      track.scrollTo({
        left: slides[idx].offsetLeft,
        behavior: reduce ? "auto" : "smooth",
      });
      setActive(idx);
    };

    // Keep dots honest if the visitor swipes by hand rather than using a dot
    // or arrow.
    track?.addEventListener(
      "scroll",
      () => {
        if (rafId) return;
        rafId = requestAnimationFrame(() => {
          rafId = 0;
          if (!track || !track.clientWidth) return;
          const idx = Math.round(track.scrollLeft / track.clientWidth);
          const clamped = Math.min(Math.max(idx, 0), slides.length - 1);
          if (clamped !== current) setActive(clamped);
        });
      },
      { passive: true }
    );

    dots.forEach((d, idx) => d.addEventListener("click", () => goTo(idx)));
    prevBtn?.addEventListener("click", () => goTo(current - 1));
    nextBtn?.addEventListener("click", () => goTo(current + 1));

    setActive(0);
  }
</script>
