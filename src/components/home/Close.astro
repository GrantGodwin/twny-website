---
// Close — an invitation, not a funnel. One Ember decision, surrounded by space,
// over a final image of light arriving in a quiet room.
import Button from "../ui/Button.astro";
import Photo from "./Photo.astro";
---

<section class="relative">
  <Photo
    src="/images/close.webp"
    alt="Soft daylight reaching into the corner of a calm, quiet room."
    class="relative min-h-[92svh]"
    scrimClass="bg-gradient-to-t from-black/85 via-black/55 to-black/45"
  >
    <div class="mx-auto flex min-h-[92svh] max-w-6xl flex-col justify-center px-6 sm:px-10">
      <div class="max-w-2xl">
        <p
          data-animate
          class="font-mono text-xs uppercase tracking-[0.22em] text-white/65 mb-7"
        >
          The next step
        </p>
        <h2
          data-animate
          class="font-display text-4xl font-semibold leading-[1.04] text-white text-balance sm:text-6xl"
        >
          Let's make your business feel handled.
        </h2>
        <p
          data-animate
          class="mt-7 max-w-xl text-lg leading-relaxed text-white/80 text-pretty"
        >
          Tell us where things stand today. We'll show you what calm could look
          like — no pressure, no script.
        </p>
        <div data-animate class="mt-10">
          <Button href="/contact" variant="ember">Start a conversation</Button>
        </div>
      </div>
    </div>
  </Photo>
</section>
