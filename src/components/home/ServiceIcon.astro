---
// Small line icon for a "what we look after" service label. Uses Lucide icon
// geometry (ISC-licensed, https://lucide.dev) for a consistent, professional
// set: 24×24 viewBox, 2px stroke, round caps/joins, outline only, currentColor.
// Maps known labels to a glyph; anything unmapped falls back to a quiet dot so
// new labels never break the layout.
interface Props {
  name: string;
  class?: string;
  size?: number;
}
// Size is set here (explicit width/height attributes) rather than via the
// caller's CSS class: Astro scopes styles per component, so a class from the
// parent won't reach this child SVG — attributes guarantee a uniform size.
const { name, class: className = "", size = 16 } = Astro.props;
const key = name.trim().toLowerCase();

const known = [
  "microsoft 365",
  "security",
  "devices",
  "website",
  "web presence",
  "ongoing support",
  "backup",
  "compliance",
  "ai workflows",
  "practice systems",
];
const isKnown = known.includes(key);
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {/* layout-grid */}
  {
    key === "microsoft 365" && (
      <Fragment>
        <rect width="7" height="7" x="3" y="3" rx="1" />
        <rect width="7" height="7" x="14" y="3" rx="1" />
        <rect width="7" height="7" x="14" y="14" rx="1" />
        <rect width="7" height="7" x="3" y="14" rx="1" />
      </Fragment>
    )
  }
  {/* shield-check */}
  {
    key === "security" && (
      <Fragment>
        <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
        <path d="m9 12 2 2 4-4" />
      </Fragment>
    )
  }
  {/* monitor */}
  {
    key === "devices" && (
      <Fragment>
        <rect width="20" height="14" x="2" y="3" rx="2" />
        <line x1="8" x2="16" y1="21" y2="21" />
        <line x1="12" x2="12" y1="17" y2="21" />
      </Fragment>
    )
  }
  {/* globe */}
  {
    (key === "website" || key === "web presence") && (
      <Fragment>
        <circle cx="12" cy="12" r="10" />
        <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
        <path d="M2 12h20" />
      </Fragment>
    )
  }
  {/* life-buoy */}
  {
    key === "ongoing support" && (
      <Fragment>
        <circle cx="12" cy="12" r="10" />
        <path d="m4.93 4.93 4.24 4.24" />
        <path d="m14.83 9.17 4.24-4.24" />
        <path d="m14.83 14.83 4.24 4.24" />
        <path d="m9.17 14.83-4.24 4.24" />
        <circle cx="12" cy="12" r="4" />
      </Fragment>
    )
  }
  {/* database */}
  {
    key === "backup" && (
      <Fragment>
        <ellipse cx="12" cy="5" rx="9" ry="3" />
        <path d="M3 5V19A9 3 0 0 0 21 19V5" />
        <path d="M3 12A9 3 0 0 0 21 12" />
      </Fragment>
    )
  }
  {/* clipboard-check */}
  {
    key === "compliance" && (
      <Fragment>
        <rect width="8" height="4" x="8" y="2" rx="1" ry="1" />
        <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />
        <path d="m9 14 2 2 4-4" />
      </Fragment>
    )
  }
  {/* sparkles */}
  {
    key === "ai workflows" && (
      <Fragment>
        <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.582a.5.5 0 0 1 0 .962L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z" />
        <path d="M20 3v4" />
        <path d="M22 5h-4" />
        <path d="M4 17v2" />
        <path d="M5 18H3" />
      </Fragment>
    )
  }
  {/* settings-2 */}
  {
    key === "practice systems" && (
      <Fragment>
        <path d="M20 7h-9" />
        <path d="M14 17H5" />
        <circle cx="17" cy="17" r="3" />
        <circle cx="7" cy="7" r="3" />
      </Fragment>
    )
  }
  {!isKnown && <circle cx="12" cy="12" r="3" />}
</svg>
