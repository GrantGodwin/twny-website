---
// A breath between the thesis and the evidence — one full-bleed image, one
// quiet line. Pure atmosphere; it explains nothing.
import Photo from "./Photo.astro";
---

<section class="relative">
  <Photo
    src="/images/divider.webp"
    alt="Late light and long shadows falling across a plain wall."
    class="relative min-h-[62svh]"
    scrimClass="bg-gradient-to-t from-black/70 via-black/30 to-black/30"
  >
    <div class="mx-auto flex min-h-[62svh] max-w-6xl items-center px-6 sm:px-10">
      <p
        data-animate
        class="max-w-2xl font-display text-2xl font-medium leading-snug text-white text-balance sm:text-3xl lg:text-4xl"
      >
        This is the feeling we protect.
      </p>
    </div>
  </Photo>
</section>
