---
// Restrained line marks for the "What we look after" capability columns.
// Deliberately literal (mail, window, lock, loop) rather than abstract tech
// iconography — no orbs, nodes, shields or circuitry (art-direction §"hard
// nevers").
interface Props {
  name: "communication" | "presence" | "protection" | "automation";
  class?: string;
}
const { name, class: className = "h-9 w-9" } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="0.85"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {
    name === "communication" && (
      <>
        <rect x="3" y="5.5" width="18" height="13" rx="1.5" />
        <path d="M4 7l8 6 8-6" />
      </>
    )
  }
  {
    name === "presence" && (
      <>
        <rect x="3" y="4.5" width="18" height="15" rx="1.5" />
        <path d="M3 8.5h18" />
      </>
    )
  }
  {
    name === "protection" && (
      <>
        <rect x="5" y="11" width="14" height="9" rx="1.5" />
        <path d="M8 11V8a4 4 0 0 1 8 0v3" />
      </>
    )
  }
  {
    name === "automation" && (
      <>
        <path d="M4 9a8 8 0 0 1 14-4.5M20 4v4h-4" />
        <path d="M20 15a8 8 0 0 1-14 4.5M4 20v-4h4" />
      </>
    )
  }
</svg>
