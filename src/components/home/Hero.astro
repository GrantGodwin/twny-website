---
import Button from "../ui/Button.astro";
import Photo from "./Photo.astro";

const signals = [
  "Microsoft 365",
  "AI readiness",
  "websites",
  "domains",
  "backup",
  "automation",
];
---

<section class="relative isolate overflow-hidden bg-[#090d11] text-white">
  <div
    class="absolute inset-0 bg-[linear-gradient(130deg,#090d11_0%,#101820_52%,#17252d_100%)]"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute inset-x-0 bottom-0 h-40 bg-[linear-gradient(to_top,#090d11_0%,rgba(9,13,17,0)_100%)]"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto grid min-h-[100svh] max-w-6xl items-end gap-8 px-6 pb-12 pt-24 sm:px-10 sm:gap-12 sm:pb-16 sm:pt-28 lg:grid-cols-[0.95fr_1.05fr] lg:items-center lg:pb-20 lg:pt-28">
    <div class="relative z-10 max-w-3xl">
      <p
        data-animate
        class="font-mono text-xs uppercase tracking-[0.16em] text-mineral"
      >
        Boutique technology practice for modern business
      </p>
      <h1
        data-animate
        class="mt-5 max-w-4xl font-display text-4xl font-semibold leading-[1] text-white text-balance sm:mt-7 sm:text-6xl sm:leading-[0.98] lg:text-7xl"
      >
        The technology behind your business, looked after.
      </h1>
      <p
        data-animate
        class="mt-5 max-w-2xl text-lg leading-relaxed text-white/78 text-pretty sm:mt-7 sm:text-xl"
      >
        Microsoft 365, AI, websites, domains, hosting, backup and automation,
        handled by one accountable operator.
      </p>

      <div data-animate class="mt-7 flex flex-wrap items-center gap-x-8 gap-y-4 sm:mt-10">
        <Button href="/contact" variant="ember">Start a conversation</Button>
        <a
          href="/pricing"
          class="text-sm font-medium text-white/78 transition-colors hover:text-white"
        >
          See pricing
        </a>
      </div>

      <ul
        data-animate
        class="mt-12 hidden max-w-2xl flex-wrap gap-x-3 gap-y-3 sm:flex"
        aria-label="Technology TWNY looks after"
      >
        {
          signals.map((signal) => (
            <li class="border border-white/12 bg-white/[0.045] px-3 py-2 font-mono text-[0.68rem] uppercase tracking-[0.13em] text-white/68 backdrop-blur-sm">
              {signal}
            </li>
          ))
        }
      </ul>
    </div>

    <div data-animate class="relative z-10 lg:justify-self-end">
      <div class="relative min-h-[310px] overflow-hidden border border-white/10 bg-white/[0.04] shadow-2xl shadow-black/35 sm:min-h-[560px]">
        <Photo
          src="/images/chapter-craft.webp"
          alt="A craft business owner working at a bench in a busy workshop."
          eager={true}
          class="absolute inset-0"
          imgClass="object-[58%_50%] saturate-[0.9] contrast-[1.04]"
          scrimClass="bg-[linear-gradient(to_top,rgba(5,8,11,0.82)_0%,rgba(5,8,11,0.28)_48%,rgba(5,8,11,0.1)_100%)]"
        />

        <div class="absolute left-4 top-4 max-w-[16rem] border border-white/12 bg-[#0d151a]/88 p-3 backdrop-blur-md sm:left-5 sm:top-5 sm:max-w-[17rem] sm:p-4">
          <p class="font-mono text-[0.66rem] uppercase tracking-[0.14em] text-mineral">
            Microsoft 365
          </p>
          <p class="mt-2 text-sm leading-snug text-white/82">
            Email, files and identity treated as the business work surface.
          </p>
        </div>

        <div class="absolute bottom-4 left-4 right-4 grid gap-3 sm:bottom-5 sm:left-5 sm:right-5 sm:grid-cols-2">
          <div class="border border-white/12 bg-[#0d151a]/88 p-4 backdrop-blur-md">
            <p class="font-mono text-[0.66rem] uppercase tracking-[0.14em] text-mineral">
              Web presence
            </p>
            <p class="mt-2 text-sm leading-snug text-white/82">
              Website, hosting and domain ownership kept together.
            </p>
          </div>
          <div class="border border-white/12 bg-[#0d151a]/88 p-4 backdrop-blur-md">
            <p class="font-mono text-[0.66rem] uppercase tracking-[0.14em] text-mineral">
              Readiness
            </p>
            <p class="mt-2 text-sm leading-snug text-white/82">
              Backup, recovery, AI and automation introduced with context.
            </p>
          </div>
        </div>
      </div>

      <div class="mt-4 flex items-center justify-between gap-5 border-t border-white/12 pt-4 text-xs text-white/58">
        <span>Modern business context</span>
        <span class="font-mono uppercase tracking-[0.12em] text-mineral">
          operational evidence visible
        </span>
      </div>
    </div>
  </div>
</section>
