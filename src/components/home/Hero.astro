---
import Button from "../ui/Button.astro";
import Photo from "./Photo.astro";

// HERO — full-bleed background image across the entire hero, sitting behind
// the floating header and the type block. Dark-first.
//
// IMAGE: hero-lighthouse.webp — supplied by the project owner / art director.
// Dark coastal headland at night: lighthouse on the right third, beam projecting
// left, a long-exposure road light-trail leading up to it, large negative space on
// the left for the headline, deep Ink-blue tones with restrained warm highlights.
// Metaphor, not literal technology — guidance, clarity, quiet competence, operating
// in the background. Provenance/licence: supplied by project owner.

const email = "hello@twny.com.au";
---

<section
  data-hero
  class="relative isolate min-h-[100svh] overflow-hidden bg-sand text-ink"
>
  {/* full-bleed background layer — covers the entire hero, behind the header
      and content. object-position keeps the lighthouse/beam in frame at
      every breakpoint. */}
  <Photo
    src="/images/hero-lighthouse.webp"
    alt=""
    eager={true}
    class="absolute inset-0 h-full w-full"
    imgClass="object-[97%_18%] sm:object-[92%_30%] lg:object-right"
    scrimClass="hero-edge-scrim"
  />

  {/* soft local scrim behind the headline/body, just enough to lift contrast */}
  <div
    class="hero-text-scrim absolute inset-y-0 left-0 w-[58%] opacity-60 sm:w-[52%] sm:opacity-50 lg:w-[46%] lg:opacity-40"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative z-10 mx-auto grid min-h-[100svh] max-w-6xl items-center gap-10 px-5 pb-20 pt-32 sm:px-8 lg:grid-cols-2 lg:gap-12 lg:pb-24"
  >
    {/* left: headline, body, actions */}
    <div class="max-w-[510px]">
      <h1
        data-animate
        class="font-display text-5xl font-semibold leading-[0.98] text-balance sm:text-6xl lg:text-[4.4rem]"
      >
        Technology, <span class="text-mineral">simplified.</span>
      </h1>
      <p
        data-animate
        class="mt-7 max-w-md text-base leading-relaxed text-white/[0.84] text-pretty lg:text-lg"
      >
        Most businesses don't want to think about technology. They just want
        it to work.
      </p>
      <p
        data-animate
        class="mt-4 max-w-md text-base leading-relaxed text-white/[0.84] text-pretty lg:text-lg"
      >
        That's what we're here for — quietly, reliably, in the background.
      </p>

      <div data-animate class="mt-9 flex flex-wrap items-center gap-x-8 gap-y-4">
        <Button href={`mailto:${email}`} variant="ember">Get in touch</Button>
        <Button href="#what-we-look-after" variant="mineral" arrow="down">
          What we look after
        </Button>
      </div>
    </div>

  </div>
</section>
