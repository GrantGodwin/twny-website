---
import Button from "../ui/Button.astro";
import Photo from "./Photo.astro";

// HERO — full-bleed background image across the entire hero, sitting behind
// the floating header and the type block. Dark-first.
//
// IMAGE: hero-lighthouse.webp — supplied by the project owner / art director.
// Dark coastal headland at night: lighthouse on the right third, beam projecting
// left, a long-exposure road light-trail leading up to it, large negative space on
// the left for the headline, deep Ink-blue tones with restrained warm highlights.
// Metaphor, not literal technology — guidance, clarity, quiet competence, operating
// in the background. Provenance/licence: supplied by project owner.
---

<section class="relative isolate min-h-[100svh] overflow-hidden bg-sand text-ink">
  {/* full-bleed background layer — covers the entire hero, behind the header
      and content. object-position keeps the lighthouse/beam in frame at
      every breakpoint. */}
  <Photo
    src="/images/hero-lighthouse.webp"
    alt=""
    eager={true}
    class="absolute inset-0 h-full w-full"
    imgClass="object-[92%_24%] sm:object-[86%_32%] lg:object-right"
    scrimClass="hero-edge-scrim"
  />

  {/* soft local scrim behind the headline/body, just enough to lift contrast */}
  <div
    class="hero-text-scrim absolute inset-y-0 left-0 w-[58%] opacity-85 sm:w-[52%] sm:opacity-70 lg:w-[46%] lg:opacity-55"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative z-10 mx-auto grid min-h-[100svh] max-w-6xl items-center gap-10 px-5 pb-16 pt-28 sm:px-8 lg:grid-cols-2 lg:gap-12 lg:pb-20"
  >
    {/* left: headline, body, actions */}
    <div class="max-w-xl">
      <h1
        data-animate
        class="font-display text-5xl font-semibold leading-[0.98] text-balance sm:text-6xl lg:text-[4.4rem]"
      >
        Technology, <span class="text-mineral">simplified.</span>
      </h1>
      <p
        data-animate
        class="mt-7 max-w-md text-base leading-relaxed text-steel text-pretty"
      >
        We take responsibility for the technology behind your business, bringing
        Microsoft 365, your website, domains, backup and AI together under one
        accountable operator.
      </p>
      <p
        data-animate
        class="mt-4 max-w-md text-base leading-relaxed text-steel text-pretty"
      >
        So everything works together, quietly, and you always know who's
        responsible.
      </p>

      <div data-animate class="mt-9 flex flex-wrap items-center gap-x-7 gap-y-4">
        <Button href="/contact" variant="ember">Let's talk</Button>
        <Button href="#how-we-work" variant="mineral">How we work</Button>
      </div>
    </div>

  </div>
</section>
