---
import Button from "../ui/Button.astro";
import Photo from "./Photo.astro";
---

<section class="relative isolate overflow-hidden bg-sand text-ink">
  {/* Atmospheric Ink wash — depth, never a loud two-colour gradient. */}
  <div
    class="absolute inset-0 bg-[radial-gradient(120%_95%_at_84%_12%,#163742_0%,rgba(10,13,17,0)_56%),linear-gradient(165deg,#090c10_0%,#0b1117_55%,#0d1b22_100%)]"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute inset-x-0 bottom-0 h-44 bg-[linear-gradient(to_top,var(--color-sand),transparent)]"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative mx-auto grid min-h-[100svh] max-w-6xl items-center gap-10 px-5 pb-16 pt-28 sm:px-8 lg:grid-cols-[1.06fr_0.94fr] lg:gap-14 lg:pb-20"
  >
    <div class="relative z-10 max-w-2xl">
      {/* the Mineral thread — quietly foreshadows the operating-layer signature */}
      <div
        class="absolute -left-5 top-1.5 hidden h-[calc(100%-0.5rem)] w-px bg-[linear-gradient(to_bottom,var(--color-mineral),rgba(58,166,201,0))] sm:block"
        aria-hidden="true"
      >
      </div>

      <p
        data-animate
        class="font-mono text-xs uppercase tracking-[0.18em] text-mineral"
      >
        Boutique technology practice · Australian small business
      </p>
      <h1
        data-animate
        class="mt-6 font-display text-5xl font-semibold leading-[0.98] text-balance sm:text-6xl lg:text-[4.6rem]"
      >
        We look after the <span class="text-mineral">technology</span> your
        business runs on.
      </h1>
      <p
        data-animate
        class="mt-7 max-w-xl text-lg leading-relaxed text-steel text-pretty sm:text-xl"
      >
        Microsoft 365, your website, domains, backup, AI and automation — the
        systems behind a modern business, kept working as one, by people you can
        actually call.
      </p>

      <div
        data-animate
        class="mt-9 flex flex-wrap items-center gap-x-7 gap-y-4"
      >
        <Button href="/contact" variant="ember">Tell us what you need</Button>
        <Button href="/pricing" variant="mineral">See pricing</Button>
      </div>
    </div>

    <div data-animate class="relative z-10">
      <div
        class="relative min-h-[420px] w-full overflow-hidden border border-line/80 shadow-2xl shadow-black/40 sm:min-h-[560px] lg:ml-auto lg:max-w-md"
      >
        <Photo
          src="/images/chapter-craft.webp"
          alt="A small-business owner at work in a busy modern workshop, laptop and job sheets in view."
          eager={true}
          class="absolute inset-0"
          imgClass="object-[58%_50%] saturate-[0.92] contrast-[1.03]"
          scrimClass="bg-[linear-gradient(to_top,rgba(7,10,14,0.92)_0%,rgba(7,10,14,0.32)_52%,rgba(7,10,14,0.12)_100%)]"
        />

        {/* one quiet operational cue — category clarity, not a dashboard */}
        <div class="absolute inset-x-5 bottom-5 border-l-2 border-mineral pl-4">
          <p
            class="font-mono text-[0.64rem] uppercase tracking-[0.16em] text-mineral"
          >
            What we look after
          </p>
          <p class="mt-1.5 text-sm leading-snug text-white/90">
            Microsoft 365 · website · domain · backup · automation — held as one.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
