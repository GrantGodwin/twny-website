---
import Button from "../ui/Button.astro";
import Photo from "./Photo.astro";

// HERO — type block left, large atmospheric image block right (matches supplied
// layout). Dark-first; image bleeds to the right edge with a quiet caption.
//
// IMAGE: hero-lighthouse.webp — supplied by the project owner / art director.
// Dark coastal headland at night: lighthouse on the right third, beam projecting
// left, a long-exposure road light-trail leading up to it, large negative space on
// the left for the headline, deep Ink-blue tones with restrained warm highlights.
// Metaphor, not literal technology — guidance, clarity, quiet competence, operating
// in the background. Provenance/licence: supplied by project owner.
---

<section class="relative isolate overflow-hidden bg-sand text-ink">
  {/* large image block on the right, bleeding to the viewport edge */}
  <div
    class="absolute inset-y-0 right-0 hidden w-[52%] lg:block"
    aria-hidden="true"
  >
    <div class="relative h-full w-full">
      <Photo
        src="/images/hero-lighthouse.webp"
        alt=""
        eager={true}
        class="absolute inset-0"
        imgClass="object-[70%_45%] saturate-[0.95] contrast-[1.03] brightness-[0.96]"
        scrimClass="bg-[linear-gradient(90deg,var(--color-sand)_0%,rgba(10,13,17,0.6)_18%,rgba(10,13,17,0.12)_50%,rgba(10,13,17,0.04)_100%)]"
      />
    </div>
  </div>

  <div
    class="relative z-10 mx-auto grid min-h-[92svh] max-w-6xl items-center gap-10 px-5 pb-16 pt-28 sm:px-8 lg:grid-cols-2 lg:gap-12 lg:pb-20"
  >
    {/* left: headline, body, actions */}
    <div class="max-w-xl">
      <h1
        data-animate
        class="font-display text-5xl font-semibold leading-[0.98] text-balance sm:text-6xl lg:text-[4.4rem]"
      >
        Technology, <span class="text-mineral">simplified.</span>
      </h1>
      <p
        data-animate
        class="mt-7 max-w-md text-base leading-relaxed text-steel text-pretty"
      >
        We take responsibility for the technology behind your business, bringing
        Microsoft 365, your website, domains, backup and AI together under one
        accountable operator.
      </p>
      <p
        data-animate
        class="mt-4 max-w-md text-base leading-relaxed text-steel text-pretty"
      >
        So everything works together, quietly, and you always know who's
        responsible.
      </p>

      <div data-animate class="mt-9 flex flex-wrap items-center gap-x-7 gap-y-4">
        <Button href="/contact" variant="ember">Let's talk</Button>
        <Button href="#how-we-work" variant="mineral">How we work</Button>
      </div>
    </div>

    {/* right: caption sitting over the image, lower edge */}
    <div class="hidden lg:flex lg:h-full lg:items-end lg:justify-end">
      <div data-animate class="max-w-xs border-t border-mineral pt-4">
        <p class="font-display text-lg font-semibold text-mineral">
          The operating layer.
        </p>
        <p class="mt-2 text-sm leading-relaxed text-steel text-pretty">
          One operator.<br />Quietly in the background.
        </p>
      </div>
    </div>
  </div>
</section>
