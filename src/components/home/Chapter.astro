---
// Editorial chapter — a full-height image/text spread. Alternating sides
// (`flip`) give the page a magazine cadence. Outcomes, not mechanics.
import Photo from "./Photo.astro";

interface Props {
  idx: string;
  kicker: string;
  heading: string;
  body: string;
  src: string;
  alt: string;
  flip?: boolean;
  id?: string;
}
const { idx, kicker, heading, body, src, alt, flip = false, id } = Astro.props;
---

<section id={id} class="bg-sand scroll-mt-24">
  <div class="grid lg:min-h-[88svh] lg:grid-cols-2">
    <div class:list={["relative min-h-[58svh] lg:min-h-full", flip && "lg:order-2"]}>
      <Photo
        src={src}
        alt={alt}
        class="absolute inset-0"
        scrimClass="bg-gradient-to-t from-black/35 via-transparent to-black/10"
      />
    </div>
    <div class:list={["flex items-center", flip && "lg:order-1"]}>
      <div
        data-animate
        class="mx-auto w-full max-w-xl px-6 py-20 sm:px-10 lg:px-16 lg:py-28"
      >
        <p class="font-mono text-xs uppercase tracking-[0.22em] text-mineral mb-7">
          {idx} — {kicker}
        </p>
        <h2 class="font-display text-4xl font-semibold leading-[1.04] text-ink text-balance sm:text-5xl">
          {heading}
        </h2>
        <p class="mt-7 text-lg leading-relaxed text-steel text-pretty">
          {body}
        </p>
      </div>
    </div>
  </div>
</section>
