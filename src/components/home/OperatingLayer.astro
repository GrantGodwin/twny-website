---
// THE SIGNATURE COMPONENT — "The Operating Layer".
// Several real systems, threaded onto one continuous Mineral line: the visual
// sentence for simplification — separate things, held and looked after as one.
// Editorial, type-led, holds as a still image.
// NOT a dashboard, card grid, chip row, or flowchart.
// Signature-device rules: docs/governance/art-direction.md
const layer = [
  {
    label: "Modern Workplace",
    line: "Email, files and identity on one clean Microsoft 365 tenant the business owns.",
  },
  {
    label: "Web Presence",
    line: "The website and domains people find you through — live, current, and yours.",
  },
  {
    label: "Backup & Recovery",
    line: "A way back for the day something is deleted, broken or compromised.",
  },
  {
    label: "AI & Automation",
    line: "Repeated work made lighter — introduced carefully, when you're ready.",
  },
  {
    label: "Advice & Support",
    line: "An operator who already knows your setup, and picks up the phone.",
  },
];
---

<section class="bg-band text-ink">
  <div class="mx-auto max-w-6xl px-5 sm:px-8 py-24 lg:py-32">
    <div class="grid gap-12 lg:grid-cols-[0.82fr_1.18fr] lg:gap-16">
      <div data-animate>
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-mineral">
          The operating layer
        </p>
        <h2 class="mt-6 font-display text-4xl font-semibold leading-[1.03] text-balance sm:text-5xl">
          Separate systems.<br /><span class="text-steel">One operation.</span>
        </h2>
        <p class="mt-6 max-w-md text-lg leading-relaxed text-steel text-pretty">
          The pieces a modern business runs on are usually scattered across four
          providers, with nobody accountable for how they fit. We hold them on one
          thread — and look after them as one.
        </p>
      </div>

      <div data-animate class="relative">
        {/* the single continuous Mineral thread */}
        <div
          class="absolute left-[7px] top-3 bottom-3 w-px bg-[linear-gradient(to_bottom,rgba(58,166,201,0)_0%,var(--color-mineral)_10%,var(--color-mineral)_90%,rgba(58,166,201,0)_100%)]"
          aria-hidden="true"
        >
        </div>

        <ul>
          {
            layer.map((row) => (
              <li class="relative grid gap-1.5 border-t border-line py-6 pl-10 sm:grid-cols-[0.4fr_0.6fr] sm:gap-8 sm:py-7">
                <span
                  class="absolute left-0 top-[1.95rem] h-[15px] w-[15px] rounded-full border border-mineral bg-band"
                  aria-hidden="true"
                />
                <span
                  class="absolute left-[5px] top-[2.26rem] h-[5px] w-[5px] rounded-full bg-mineral"
                  aria-hidden="true"
                />
                <h3 class="font-display text-xl font-semibold text-ink">
                  {row.label}
                </h3>
                <p class="text-base leading-relaxed text-steel text-pretty">
                  {row.line}
                </p>
              </li>
            ))
          }
        </ul>
        <p class="mt-7 pl-10 text-sm leading-relaxed text-steel text-pretty">
          One thread, one source of truth, one operator who picks up the phone —
          and you can take all of it with you, any time.
        </p>
      </div>
    </div>
  </div>
</section>
