---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import FAQ from "../components/blocks/FAQ.astro";
import CapabilityIcon from "../components/home/CapabilityIcon.astro";
import {
  serviceCapabilities,
  heroBreadth,
  engagementShape,
  taxonomy,
  serviceFaqs,
} from "../data/services";

// One considered page, not the homepage's alternating chapters: a single
// editorial surface (paper) carries all four capabilities, separated by
// spacing, typography and hairlines rather than a colour change between
// each one. Only two surface transitions on the whole page (sand → paper →
// band), so it reads calmer and more operational than the homepage.
const email = "hello@twny.com.au";

const breadthSize: Record<string, string> = {
  base: "text-base",
  lg: "text-lg sm:text-xl",
  xl: "text-xl sm:text-2xl",
};

// Splits `text` on any of `terms`, used to render named technologies as
// Mineral inline accents within otherwise plain body copy (the "woven" and
// "compact" capability layouts) instead of a separate tag line.
function withHighlights(text: string, terms: string[] = []) {
  if (!terms.length) return [text];
  const escaped = terms.map((t) => t.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"));
  return text.split(new RegExp(`(${escaped.join("|")})`, "g"));
}
---

<BaseLayout
  title="Services — TWNY"
  description="Microsoft 365, websites, domains, DNS, email, backup, security, Copilot and practical automation — the everyday technology behind your business, looked after by one accountable operator."
>
  {/* INTRO — the visual anchor is informational, not decorative: a small,
      hand-set cluster of the breadth of what we cover, in Mineral, beside
      the headline. No gradient, no illustration, no icon grid — just a
      second, quieter typographic voice answering "what do you actually
      do" in under a second. */}
  <section class="bg-sand">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 sm:py-28">
      <div class="grid gap-14 lg:grid-cols-[1.1fr_auto] lg:items-start lg:gap-20">
        <div>
          <p class="font-mono text-xs uppercase tracking-widest text-mineral mb-3">
            Services
          </p>
          <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold leading-[1.07] text-ink max-w-2xl text-balance">
            The technology your business runs on.
          </h1>
          <p class="mt-5 text-lg text-steel leading-relaxed max-w-xl text-pretty">
            Looked after as one connected operation, by someone who already
            knows your setup — not a list of separate things to manage.
          </p>
          <div class="mt-9">
            <Button href={`mailto:${email}`} variant="ember">Get in touch</Button>
          </div>
        </div>

        <div class="lg:border-l lg:border-mineral/20 lg:pl-14 lg:pt-1">
          <p class="font-mono text-xs uppercase tracking-widest text-steel/60 mb-5">
            Across all of it
          </p>
          <div class="grid grid-cols-2 gap-x-10 gap-y-3">
            {
              heroBreadth.map((item) => (
                <span class={`font-display font-medium leading-snug text-mineral ${breadthSize[item.size]}`}>
                  {item.term}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* THE FOUR CAPABILITIES — one continuous editorial surface, no section
      eyebrow/heading of its own; a small Mineral rule marks the start of
      the zone. Each row's `layout` varies how the technology line and the
      closing "moment" are rendered, so the eye doesn't learn one fixed
      rhythm after the first two rows. */}
  <section class="bg-paper border-y border-line">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 sm:py-28">
      <div class="h-0.5 w-10 bg-mineral mb-14 lg:mb-16" aria-hidden="true" />

      <div class="divide-y divide-line">
        {
          serviceCapabilities.map((c) => (
            <div class="grid gap-5 py-14 first:pt-0 last:pb-0 lg:grid-cols-[260px_1fr] lg:gap-16 lg:py-16">
              <div>
                <CapabilityIcon name={c.icon} class="h-6 w-6 text-mineral mb-3" />
                <h2 class="font-display text-2xl font-medium leading-snug text-ink text-balance sm:text-3xl">
                  {c.heading}
                </h2>
              </div>
              <div class="max-w-2xl">
                <p class="text-base font-medium leading-snug text-ink/90 text-pretty sm:text-lg">
                  {c.lead}
                </p>

                <p class="mt-3 text-steel leading-relaxed text-pretty">
                  {withHighlights(c.body, c.highlight).map((part) =>
                    c.highlight?.includes(part) ? <span class="text-mineral">{part}</span> : part
                  )}
                </p>

                {c.techLine && (
                  <p class="mt-5 border-l-2 border-mineral/40 pl-3 font-mono text-xs uppercase tracking-widest text-mineral/80">
                    {c.techLine.join(" · ")}
                  </p>
                )}

                {c.moment && c.layout === "quote" ? (
                  <div class="mt-6 border-l-2 border-mineral/50 pl-4">
                    <p class="font-mono text-xs uppercase tracking-widest text-mineral/55 mb-1.5">
                      {c.moment.label}
                    </p>
                    <p class="max-w-xl font-display text-base italic leading-relaxed text-ink/90 text-pretty sm:text-lg">
                      {c.moment.body}
                    </p>
                  </div>
                ) : (
                  c.moment && (
                    <>
                      <p class="mt-5 font-mono text-xs uppercase tracking-widest text-mineral/55">
                        {c.moment.label}
                      </p>
                      <p class="mt-2 max-w-xl text-sm leading-relaxed text-steel/85 text-pretty">
                        {c.moment.body}
                      </p>
                    </>
                  )
                )}
              </div>
            </div>
          ))
        }
      </div>

      {/* EVERYTHING, BY NAME — a premium taxonomy, not a bullet list, a
          pricing table or feature cards: large, scannable text in a
          multi-column index with a Mineral rule between columns. Answers
          "do these people do the thing I'm looking for" without a single
          paragraph. */}
      <div class="taxonomy mt-12 border-t border-line pt-10 lg:mt-14">
        <h3 class="font-display text-lg font-semibold text-ink text-balance sm:text-xl">
          {taxonomy.heading}
        </h3>
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-steel text-pretty sm:text-base">
          {taxonomy.lede}
        </p>
        <div class="taxonomy-columns mt-8 columns-2 gap-x-12 sm:columns-3">
          {
            taxonomy.items.map((item) => (
              <p class="mb-4 flex items-baseline gap-2.5 break-inside-avoid-column font-display text-base text-ink sm:text-lg">
                <span class="text-mineral" aria-hidden="true">
                  —
                </span>
                <span>{item}</span>
              </p>
            ))
          }
        </div>
      </div>

      {/* HOW THIS USUALLY STARTS — quietly introduces the commercial model
          (two ways to work with us) without pricing, packages or tiers. A
          small Mineral arrow maps the relationship between them — a focused
          project is usually the entry point, ongoing care is what it tends
          to grow into — rather than presenting two equal menu options. */}
      <div class="mt-12 max-w-3xl border-t border-line pt-10 lg:mt-14">
        <h3 class="font-display text-lg font-semibold text-ink text-balance sm:text-xl">
          {engagementShape.heading}
        </h3>
        <p class="mt-3 max-w-2xl text-sm leading-relaxed text-steel text-pretty sm:text-base">
          {engagementShape.intro}
        </p>

        <div class="engagement-path mt-8 flex flex-col gap-6 sm:flex-row sm:items-stretch sm:gap-2">
          <div class="max-w-sm">
            <p class="font-mono text-xs uppercase tracking-widest text-mineral/80">
              {engagementShape.focused.label}
            </p>
            <p class="mt-2 text-sm leading-relaxed text-steel text-pretty sm:text-base">
              {engagementShape.focused.description}
            </p>
          </div>

          <div
            class="engagement-arrow flex shrink-0 items-center self-center text-mineral/60 sm:self-stretch"
            aria-hidden="true"
          >
            →
          </div>

          <div class="max-w-sm">
            <p class="font-mono text-xs uppercase tracking-widest text-mineral/55">
              {engagementShape.ongoing.label}
            </p>
            <p class="mt-2 text-sm leading-relaxed text-steel text-pretty sm:text-base">
              {engagementShape.ongoing.description}
            </p>
          </div>
        </div>

        <p class="mt-8 max-w-2xl text-sm font-medium leading-relaxed text-ink/90 text-pretty sm:text-base">
          {engagementShape.reassurance}
        </p>
      </div>
    </div>
  </section>

  {/* EMBEDDED FAQ + CLOSING CTA — the page's one remaining surface shift,
      grouping "clear the last objection" and "the decision" into a single
      band rather than two more chapters. */}
  <section class="bg-band">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 sm:py-24">
      <div class="mb-8">
        <h2 class="font-mono text-xs uppercase tracking-widest text-steel">FAQ</h2>
      </div>
      <FAQ items={serviceFaqs} />

      <div class="mt-20 max-w-2xl border-t border-line pt-12 lg:mt-24">
        <h2 class="font-display text-3xl font-semibold leading-[1.05] text-ink text-balance sm:text-4xl">
          If it touches your business, we can probably help.
        </h2>
        <p class="mt-5 max-w-xl text-steel leading-relaxed text-pretty">
          Tell us what you're working with and we'll tell you plainly whether
          we're the right fit — and if we're not, we'll say so.
        </p>
        <div class="mt-9">
          <Button href={`mailto:${email}`} variant="ember">Get in touch</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* "Everything, by name" — a native CSS multi-column rule gives the
     index a Mineral-tinted vertical divider between columns without any
     extra markup; no card backgrounds, no gradients. */
  .taxonomy-columns {
    column-rule: 1px solid color-mix(in srgb, var(--mineral) 22%, transparent);
  }

  /* "How this usually starts" — the connecting arrow rotates to point
     downward when the two paths stack on narrow screens. */
  .engagement-arrow {
    font-size: 1.25rem;
    transform: rotate(90deg);
  }
  @media (min-width: 640px) {
    .engagement-arrow {
      transform: none;
    }
  }
</style>
