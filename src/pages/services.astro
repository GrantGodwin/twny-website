---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import FAQ from "../components/blocks/FAQ.astro";
import CapabilityIcon from "../components/home/CapabilityIcon.astro";
import { serviceCapabilities, everyday, howWeWork, serviceFaqs } from "../data/services";

// The homepage's second chapter. Same design system: tonal surface steps as
// the only section transition (no section borders, like the homepage), the
// homepage's fade-edge hairline as the only within-section divider, matched
// eyebrow/heading typography, and the three-role palette — white for
// statements, Mineral for icons / capability names / labels, Ember for the
// single action. Surfaces step like the homepage's rooms.
const email = "hello@twny.com.au";
---

<BaseLayout
  title="Services — TWNY"
  description="Email, websites, security and everything in between — the everyday technology behind your business, looked after by one person who already knows your setup."
>
  {/* HERO — the statement and the single action on the left; four calm rows
      on the right (icon + title + one sentence) so a visitor recognises
      their business without reading a paragraph. */}
  <section class="bg-sand text-ink">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 sm:py-24 lg:py-28">
      <div class="grid gap-14 lg:grid-cols-[1.05fr_1fr] lg:items-center lg:gap-20">
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-mineral mb-5">
            Services
          </p>
          <h1 class="font-display text-4xl font-semibold leading-[1.05] text-balance sm:text-5xl lg:text-[3.5rem]">
            The technology your business runs on.
          </h1>
          <p class="mt-6 max-w-md text-lg leading-relaxed text-steel text-pretty">
            Email, websites, security and everything in between — looked after
            by one person who already knows your business.
          </p>
          <div class="mt-9">
            <Button href={`mailto:${email}`} variant="ember">Get in touch</Button>
          </div>
        </div>

        <div class="space-y-8 lg:space-y-9">
          {
            serviceCapabilities.map((c) => (
              <div class="flex gap-4">
                <CapabilityIcon name={c.icon} class="mt-1 h-6 w-6 shrink-0 text-mineral" />
                <div>
                  <p class="font-display text-lg font-medium text-mineral">{c.title}</p>
                  <p class="mt-1 text-[0.95rem] leading-relaxed text-ink/70 text-pretty">
                    {c.heroLine}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  {/* WHAT WE LOOK AFTER — the homepage's section treatment (eyebrow, then
      content). Four identical editorial rows: icon, outcome headline, one
      paragraph, one reassurance. Separated only by the homepage's fade-edge
      hairline. Nothing else. */}
  <section class="bg-paper text-ink">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 lg:py-28">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-mineral">
        What we look after
      </p>

      <div class="mt-12 lg:mt-16">
        {
          serviceCapabilities.map((c) => (
            <div class="cap-row max-w-2xl py-12 first:pt-0 last:pb-0 lg:py-14">
              <CapabilityIcon name={c.icon} class="h-9 w-9 text-mineral" />
              <h2 class="mt-5 font-display text-2xl font-semibold leading-[1.12] text-balance sm:text-3xl">
                {c.headline}
              </h2>
              <p class="mt-4 text-base leading-relaxed text-steel text-pretty sm:text-lg">
                {c.body}
              </p>
              <p class="mt-5 text-base font-medium text-ink text-pretty">{c.reassurance}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* THE THINGS WE LOOK AFTER EVERY DAY — reassurance that yes, we do that.
      Five plain lists, no borders, no cards. */}
  <section class="bg-band text-ink">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 lg:py-28">
      <div class="max-w-2xl">
        <h2 class="font-display text-2xl font-semibold leading-[1.1] text-balance sm:text-3xl">
          {everyday.heading}
        </h2>
        <p class="mt-4 text-base leading-relaxed text-steel text-pretty">
          {everyday.lede}
        </p>
      </div>

      <div class="mt-14 grid grid-cols-2 gap-x-8 gap-y-10 sm:grid-cols-3 lg:mt-16 lg:grid-cols-5">
        {
          everyday.groups.map((g) => (
            <div>
              <h3 class="font-mono text-xs uppercase tracking-[0.18em] text-mineral">{g.label}</h3>
              <ul class="mt-4 space-y-2.5">
                {g.items.map((item) => (
                  <li class="text-base leading-snug text-ink/85">{item}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* WORKING TOGETHER IS SIMPLE — three plain columns, no arrows, no process
      diagram; one reassurance line beneath. */}
  <section class="bg-sand text-ink">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 lg:py-28">
      <h2 class="font-display text-2xl font-semibold leading-[1.1] text-balance sm:text-3xl">
        {howWeWork.heading}
      </h2>

      <div class="mt-14 grid gap-x-12 gap-y-10 sm:grid-cols-3 lg:mt-16">
        {
          howWeWork.steps.map((s) => (
            <div>
              <h3 class="font-display text-lg font-medium text-ink text-balance">{s.title}</h3>
              <p class="mt-3 text-base leading-relaxed text-steel text-pretty">{s.body}</p>
            </div>
          ))
        }
      </div>

      <p class="mt-14 max-w-2xl text-lg font-medium leading-relaxed text-ink text-pretty lg:mt-16">
        {howWeWork.footnote}
      </p>
    </div>
  </section>

  {/* FAQ + CLOSING — the FAQ, then the page's strongest beat: the close, left
      almost exactly as it was. */}
  <section class="bg-band text-ink">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 lg:py-28">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-steel mb-8">FAQ</p>
      <FAQ items={serviceFaqs} />

      <div class="mt-24 max-w-2xl">
        <h2 class="font-display text-3xl font-semibold leading-[1.05] text-balance sm:text-4xl lg:text-5xl">
          If it touches your business, we can probably help.
        </h2>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-steel text-pretty">
          Tell us what you're working with and we'll tell you plainly whether
          we're the right fit — and if we're not, we'll say so.
        </p>
        <div class="mt-10">
          <Button href={`mailto:${email}`} variant="ember">Get in touch</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* The homepage's fade-edge hairline (matching `.divider-fade` on the
     homepage) is the only within-section divider — between capability rows. */
  .cap-row + .cap-row {
    position: relative;
  }
  .cap-row + .cap-row::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      color-mix(in srgb, var(--line) 80%, transparent) 30%,
      color-mix(in srgb, var(--line) 80%, transparent) 70%,
      transparent
    );
  }
</style>
