---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import { capabilities } from "../data/offer";

// Placeholder services page — anchors the site's "Services" nav item and the
// homepage's secondary "explore services" links now that /#services no
// longer exists. Minimal for now; a full services IA is a separate decision.
const email = "hello@twny.com.au";
---

<BaseLayout
  title="Services — TWNY"
  description="Microsoft 365, websites, domains, backup and practical automation — the everyday technology behind your business, looked after by one accountable operator."
>
  <section class="bg-sand">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-widest text-mineral mb-3">
        Services
      </p>
      <h1 class="font-display text-3xl sm:text-4xl font-semibold text-ink max-w-2xl text-balance">
        What we look after.
      </h1>
      <p class="mt-4 text-lg text-steel leading-relaxed max-w-2xl text-pretty">
        Email, websites, devices, backup and security — the everyday
        technology behind your business, looked after by one accountable
        operator.
      </p>

      <div class="mt-9">
        <Button href={`mailto:${email}`} variant="ember">
          Get in touch
        </Button>
      </div>

      <div class="mt-10 max-w-2xl bg-band border border-line rounded-sm p-5">
        <p class="font-mono text-xs text-steel leading-relaxed">
          ▲ Prototype placeholder. A full services page is not built yet —
          this page exists to anchor navigation and "explore our services"
          links until that work is scheduled.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-paper border-y border-line">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-16 sm:py-20">
      <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
        {
          capabilities.map((c) => (
            <div>
              <h2 class="font-display text-xl font-semibold text-ink">
                {c.heading}
              </h2>
              <p class="mt-3 text-sm leading-relaxed text-steel text-pretty">
                {c.body}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
