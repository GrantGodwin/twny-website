---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import PricingToggle from "../components/blocks/PricingToggle.astro";
import PricingFlag from "../components/blocks/PricingFlag.astro";
import TierLadder from "../components/blocks/TierLadder.astro";
import ComparisonMatrix from "../components/blocks/ComparisonMatrix.astro";
import FAQ from "../components/blocks/FAQ.astro";
import CTABand from "../components/blocks/CTABand.astro";
import GstLine from "../components/blocks/GstLine.astro";
import {
  draftNotice,
  addOns,
  onboarding,
  consulting,
} from "../data/pricing";

const lineItems = [...addOns, onboarding, consulting];
---

<BaseLayout
  title="Pricing — priced in the open | TWNY"
  description="Two ways to pay: annual commitment (two months free) or monthly flex (no lock-in). Every price published, ex-GST."
>
  {/* Intro */}
  <section class="bg-sand">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-16 sm:py-20">
      <p class="font-mono text-xs uppercase tracking-widest text-mineral mb-3">
        Pricing
      </p>
      <h1 class="font-display text-3xl sm:text-4xl font-semibold text-ink max-w-2xl text-balance">
        Priced in the open.
      </h1>
      <p class="mt-4 text-lg text-steel leading-relaxed max-w-2xl text-pretty">
        Two ways to pay. Annual commitment is prepaid — two months free. Monthly
        flex is month-to-month with no lock-in. Same service either way.
      </p>
      <div class="mt-7 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <PricingToggle />
        <PricingFlag text={draftNotice} />
      </div>
    </div>
  </section>

  {/* Productivity tiers */}
  <Section
    surface="paper"
    eyebrow="Microsoft 365 — managed"
    heading="Productivity tiers."
  >
    <TierLadder />
    <div class="mt-10">
      <ComparisonMatrix />
    </div>
  </Section>

  {/* Add-ons, onboarding, consulting */}
  <Section
    surface="sand"
    eyebrow="Add-ons & one-offs"
    heading="Everything else, just as plainly."
  >
    <ul class="border border-line rounded-sm divide-y divide-line overflow-hidden">
      {
        lineItems.map((item) => (
          <li class="bg-paper p-6 grid gap-2 sm:grid-cols-[1fr_auto] sm:items-baseline sm:gap-8">
            <div>
              <h3 class="font-display font-semibold text-ink">{item.name}</h3>
              <p class="mt-1.5 text-sm text-steel leading-relaxed max-w-xl">
                {item.blurb}
              </p>
              {"flag" in item && item.flag && (
                <p class="mt-2 font-mono text-xs text-ember">▲ {item.flag}</p>
              )}
            </div>
            <span class="font-display text-lg font-semibold text-ink whitespace-nowrap">
              {item.price}
            </span>
          </li>
        ))
      }
    </ul>
  </Section>

  {/* FAQ */}
  <Section
    surface="paper"
    eyebrow="Pricing FAQ"
    heading="The questions everyone asks."
  >
    <FAQ />
    <div class="mt-8">
      <GstLine />
    </div>
  </Section>

  <CTABand />
</BaseLayout>
