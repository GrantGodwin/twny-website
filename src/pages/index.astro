---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/home/Hero.astro";
import CapabilityIcon from "../components/home/CapabilityIcon.astro";
import ClientStories from "../components/home/ClientStories.astro";
import Button from "../components/ui/Button.astro";
import { capabilities, philosophy, rotatingTerms } from "../data/offer";
---

<BaseLayout
  title="twny — Simplifying the technology behind your business"
  description="A boutique Australian technology practice. We look after the Microsoft 365, websites, domains, backup and automation behind your business — one accountable operator, fewer moving parts, and clean ownership you keep."
  heroHeader={true}
>
  {/* HERO */}
  <Hero />

  {/* WHAT WE LOOK AFTER — full-width editorial header, then four wide
      capability panels. No relationship band here — that becomes its own
      "Why TWNY" section later. */}
  <section id="what-we-look-after" class="bg-paper text-ink">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 lg:py-28">
      <div data-animate class="max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-mineral">
          What we look after
        </p>
        <h2 class="mt-6 font-display text-3xl font-semibold leading-[1.07] text-balance sm:text-4xl">
          Technology shouldn't be another job.
        </h2>
        <p class="mt-5 max-w-xl text-sm leading-relaxed text-steel text-pretty">
          We look after the technology behind your business — so things
          run smoothly day to day, and you have more time for the work
          that actually matters.
        </p>
      </div>

      <div
        data-animate
        class="capability-grid mt-5 grid grid-cols-1 sm:grid-cols-2 lg:mt-9 lg:grid-cols-4"
      >
        {
          capabilities.map((c) => (
            <div class="capability-item flex flex-col items-center text-center">
              <CapabilityIcon name={c.icon} class="h-16 w-16 text-mineral" />
              <h3 class="mt-5 font-display text-xl font-semibold leading-snug text-ink whitespace-nowrap lg:text-2xl">
                {c.heading}
              </h3>
              <p class="mt-5 max-w-[15rem] text-[0.9rem] leading-relaxed text-steel/85 text-pretty">
                {c.body}
              </p>
            </div>
          ))
        }
      </div>

      <div data-animate class="mt-16 lg:mt-20">
        <Button href="/#services" variant="mineral">
          See how we can help
        </Button>
      </div>
    </div>
  </section>

  {/* WHY TWNY — the homepage's emotional centre. Demonstrates the
      philosophy (we carry the complexity so clients don't have to) rather
      than asserting differentiation as a principles list. No cards, no
      icons, no diagram — typography and one restrained vertical-reel motion
      carry the section. The rotating term is not the feature; it's a
      specimen of the complexity being carried, so its meaning survives
      entirely intact with motion off or JS disabled (the markup's initial
      term is simply what's shown, statically). */}
  <section id="why-twny" class="bg-band text-ink">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-16 lg:py-20">
      <div data-animate class="max-w-[63rem]">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-mineral">
          Why TWNY
        </p>
        <h2 class="mt-5 font-display text-balance">
          <span class="block text-3xl font-semibold leading-[1.05] text-ink sm:text-4xl lg:text-5xl">
            Simple for you.
          </span>
          <span class="headline-secondary mt-[0.35rem] block text-[1.24rem] font-medium leading-snug sm:text-[1.375rem] lg:text-[1.65rem]">
            Never simple behind the scenes.
          </span>
        </h2>

        <p
          data-animate
          data-rotating-term-wrapper
          class="mt-3 font-display text-base leading-snug text-ink sm:text-lg lg:mt-4 lg:text-xl"
        >
          <span aria-hidden="true">
            You shouldn't need to understand
            <span class="term-reel">
              <span class="term-reel__track" data-rotating-track>
                <span
                  class="term-reel__item term-reel__item--edge font-bold italic text-ember"
                  data-reel-prev
                >
                  {rotatingTerms[rotatingTerms.length - 1]}
                </span>
                <span class="term-reel__item font-bold italic text-ember" data-reel-current>
                  {rotatingTerms[0]}
                </span>
                <span
                  class="term-reel__item term-reel__item--edge font-bold italic text-ember"
                  data-reel-next
                >
                  {rotatingTerms[1]}
                </span>
              </span>
            </span>
          </span>
          <span class="sr-only">
            You shouldn't need to understand {rotatingTerms.join(", ")}
          </span>
        </p>

        <p
          data-animate
          class="mt-3 max-w-[548px] text-sm leading-relaxed text-steel text-pretty sm:mt-4 sm:text-base"
        >
          Technology is complicated. The jargon, the platforms and the
          security requirements keep changing. We stay across it, so you
          don't have to.
        </p>
      </div>

      <div
        data-animate
        class="divider-fade relative mt-10 max-w-[54rem] pt-8 grid gap-x-8 gap-y-6 sm:grid-cols-3 lg:mt-12"
      >
        {
          philosophy.map((point) => (
            <div>
              <h3 class="font-display text-base font-semibold text-ink">
                {point.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-steel text-pretty">
                {point.body}
              </p>
            </div>
          ))
        }
      </div>

      <div data-animate class="mt-9 lg:mt-10">
        <Button href="/productivity" variant="mineral">
          See how we make it simple
        </Button>
      </div>
    </div>
  </section>

  {/* HELPING BUSINESSES LIKE YOURS — the former "Social proof" item, now a
      living, image-led editorial feature (client proof / business stories): one
      featured story at a time with a persistent, selectable roster of all the
      businesses. Self-contained in the ClientStories component (markup, styles,
      rotation script). On bg-sand to recess between the lifted Why TWNY band
      above and the lifted Pricing surface below. */}
  <ClientStories />

  {/* PRICING — kept as its own section, decoupled from Why TWNY, so the
      homepage never goes without a visible pricing teaser regardless of how
      Why TWNY's content evolves (art direction: hidden pricing is a hard
      "never"). Content/copy unchanged from the previous combined section. */}
  <section class="bg-paper text-ink">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 lg:py-28">
      <div data-animate class="max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-mineral">
          Pricing
        </p>
        <h2 class="mt-6 font-display text-3xl font-semibold leading-[1.05] text-balance sm:text-4xl">
          Priced in the open.
        </h2>
        <p class="mt-5 max-w-sm text-sm leading-relaxed text-steel text-pretty">
          Two ways to pay: annual commitment (two months free) or monthly flex
          (no lock-in). Every price is published — nothing hidden behind a sales
          call.
        </p>
        <div class="mt-7 flex flex-wrap items-center gap-x-6 gap-y-4">
          <Button href="/pricing" variant="mineralSolid">See pricing</Button>
          <Button href="/productivity" variant="mineral">
            Explore Productivity
          </Button>
        </div>
        <p class="mt-6 font-mono text-xs text-steel">
          All prices are in Australian dollars and exclude GST.
        </p>
      </div>
    </div>
  </section>

  {/* CONVERSION BAND */}
  <section class="relative isolate overflow-hidden bg-band text-ink">
    <div
      class="absolute inset-0 bg-[radial-gradient(70%_140%_at_15%_50%,rgba(19,58,71,0.6)_0%,rgba(22,29,38,0)_60%)]"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-6xl px-5 sm:px-8 py-12 lg:py-16">
      <div
        data-animate
        class="flex flex-col gap-7 lg:flex-row lg:items-center lg:justify-between lg:gap-10"
      >
        <h2 class="max-w-md font-display text-2xl font-semibold leading-[1.12] text-balance sm:text-3xl">
          Tell us what you need; we'll recommend a starting point.
        </h2>
        <p class="max-w-xs text-sm leading-relaxed text-steel text-pretty">
          No pressure, no sales funnel. A short conversation, then a clear
          recommendation.
        </p>
        <div class="shrink-0">
          <Button href="/contact" variant="ember">Tell us what you need</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* "What we look after" capability columns — quiet separators between
     columns (vertical) and rows (horizontal) as the grid wraps, without
     boxed cards. align-items: start keeps each item's own content height,
     so a divider never stretches taller than the panel it sits beside. */
  .capability-grid {
    row-gap: 4rem;
    column-gap: 2rem;
    align-items: start;
  }
  .capability-item {
    position: relative;
  }
  @media (max-width: 639px) {
    .capability-item + .capability-item::after {
      content: "";
      position: absolute;
      top: 0;
      left: 10%;
      right: 10%;
      height: 1px;
      background: linear-gradient(
        to right,
        transparent,
        color-mix(in srgb, var(--line) 48%, transparent) 30%,
        color-mix(in srgb, var(--line) 48%, transparent) 70%,
        transparent
      );
    }
    .capability-item + .capability-item {
      padding-top: 2.5rem;
    }
  }
  @media (min-width: 640px) and (max-width: 1023px) {
    .capability-item:nth-child(n + 3)::after {
      content: "";
      position: absolute;
      top: 0;
      left: 10%;
      right: 10%;
      height: 1px;
      background: linear-gradient(
        to right,
        transparent,
        color-mix(in srgb, var(--line) 48%, transparent) 30%,
        color-mix(in srgb, var(--line) 48%, transparent) 70%,
        transparent
      );
    }
    .capability-item:nth-child(n + 3) {
      padding-top: 2.5rem;
    }
    .capability-item:nth-child(even)::before {
      content: "";
      position: absolute;
      top: 16%;
      bottom: 16%;
      left: -1rem;
      width: 1px;
      background: linear-gradient(
        to bottom,
        transparent,
        color-mix(in srgb, var(--line) 48%, transparent) 30%,
        color-mix(in srgb, var(--line) 48%, transparent) 70%,
        transparent
      );
    }
  }
  @media (min-width: 1024px) {
    .capability-item:not(:first-child)::before {
      content: "";
      position: absolute;
      top: 16%;
      bottom: 16%;
      left: -1rem;
      width: 1px;
      background: linear-gradient(
        to bottom,
        transparent,
        color-mix(in srgb, var(--line) 48%, transparent) 30%,
        color-mix(in srgb, var(--line) 48%, transparent) 70%,
        transparent
      );
    }
  }

  /* "Why TWNY" philosophy row divider — the same fade-edged hairline used
     between "What we look after"'s capability columns, widened and lightened
     slightly for this wider, lower-contrast context. */
  .divider-fade::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      color-mix(in srgb, var(--line) 80%, transparent) 30%,
      color-mix(in srgb, var(--line) 80%, transparent) 70%,
      transparent
    );
  }

  /* "Why TWNY" headline — second line reads as a quieter continuation of
     the first, not a caption: a touch warmer than pure Steel, without
     reaching the full contrast of the dominant line. */
  .headline-secondary {
    color: color-mix(in srgb, var(--steel) 58%, var(--ink) 42%);
  }

  /* "Why TWNY" rotating term — sits inline immediately after "understand",
     not as a centred chip: text is left-aligned within the reel so the word
     starts right where the sentence leaves off, with any reserved width
     trailing harmlessly after it instead of opening a gap before it. The
     clipping window is exactly one line tall, so only the active term is
     ever visible at rest — no permanently-visible neighbouring terms above
     or below. The previous/next terms only become momentarily visible,
     in full pure Ember, while one slides out and the next slides into
     place; nothing fades or dims, the track itself transitions. A generous fixed
     minimum width holds the longest term, so the surrounding sentence never
     reflows as shorter or longer terms rotate through. */
  .term-reel {
    position: relative;
    display: inline-block;
    height: 1.3em;
    min-width: 18rem;
    margin-left: -0.025em;
    overflow: hidden;
    vertical-align: -0.33375em;
  }
  .term-reel__track {
    display: block;
    transform: translateY(-33.3333%);
    transition: transform 1000ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .term-reel__item {
    display: block;
    height: 1.3em;
    line-height: 1.3em;
    white-space: nowrap;
    text-align: left;
  }
  @media (min-width: 640px) {
    .term-reel {
      min-width: 20rem;
    }
  }
  @media (min-width: 1024px) {
    .term-reel {
      min-width: 22rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .term-reel {
      height: auto;
      min-width: 0;
      overflow: visible;
      vertical-align: baseline;
    }
    .term-reel__track {
      transform: none !important;
      transition: none;
    }
    .term-reel__item--edge {
      display: none;
    }
  }
</style>

<script>
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const targets = document.querySelectorAll<HTMLElement>("[data-animate]");
  if (!reduce && "IntersectionObserver" in window && targets.length) {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in");
            obs.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
    );
    targets.forEach((el) => io.observe(el));
  }
</script>

<script define:vars={{ terms: rotatingTerms }}>
  // "Why TWNY" rotating term — a vertical reel (translateY on a 3-item
  // track), not a crossfade, carousel or typing effect. ~3.8s dwell, one
  // smooth scroll per advance. Pauses on hover/focus and when scrolled out
  // of view. Under prefers-reduced-motion the CSS above hides the edge
  // slivers and strips the transform/transition entirely, so this script
  // does nothing and the markup's initial static term is simply what shows.
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const track = document.querySelector("[data-rotating-track]");
  const prevEl = document.querySelector("[data-reel-prev]");
  const currentEl = document.querySelector("[data-reel-current]");
  const nextEl = document.querySelector("[data-reel-next]");
  const wrapper = document.querySelector("[data-rotating-term-wrapper]");

  if (track && prevEl && currentEl && nextEl && !reduceMotion && terms.length > 1) {
    let index = 0;
    let hoverPaused = false;
    let outOfView = false;

    const render = () => {
      prevEl.textContent = terms[(index - 1 + terms.length) % terms.length];
      currentEl.textContent = terms[index];
      nextEl.textContent = terms[(index + 1) % terms.length];
    };
    render();

    const advance = () => {
      if (hoverPaused || outOfView) return;
      track.style.transform = "translateY(0%)";
      track.addEventListener(
        "transitionend",
        () => {
          index = (index - 1 + terms.length) % terms.length;
          track.style.transition = "none";
          track.style.transform = "translateY(-33.3333%)";
          render();
          track.getBoundingClientRect();
          requestAnimationFrame(() => {
            track.style.transition = "";
          });
        },
        { once: true }
      );
    };

    setInterval(advance, 3800);

    wrapper?.addEventListener("mouseenter", () => (hoverPaused = true));
    wrapper?.addEventListener("mouseleave", () => (hoverPaused = false));
    wrapper?.addEventListener("focusin", () => (hoverPaused = true));
    wrapper?.addEventListener("focusout", () => (hoverPaused = false));

    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) outOfView = !entry.isIntersecting;
        },
        { threshold: 0.2 }
      );
      const section = document.getElementById("why-twny");
      if (section) io.observe(section);
    }
  }
</script>
