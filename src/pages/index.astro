---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/blocks/Hero.astro";
import SurfaceNeedList from "../components/blocks/SurfaceNeedList.astro";
import ImageBand from "../components/blocks/ImageBand.astro";
import LoopStrip from "../components/blocks/LoopStrip.astro";
import OfferClusters from "../components/blocks/OfferClusters.astro";
import PrincipleGrid from "../components/blocks/PrincipleGrid.astro";
import HomeClose from "../components/blocks/HomeClose.astro";
---

<BaseLayout
  title="TWNY — We run the cloud and the website"
  heroHeader={true}
>
  {/* Position — immersive hero, mood before message */}
  <Hero
    eyebrow="Australian small business"
    heading="We run the cloud and the website so you can run the business."
    sub="Modern cloud operations and digital presence — one operator, one managed tenancy, honest edges."
    ctaLabel="Tell us what you need"
    ctaHref="/contact"
    secondaryLabel="See how we work"
    secondaryHref="#how-we-work"
  />

  {/* Prove — what you actually get (need beneath the surface) */}
  <SurfaceNeedList />

  {/* Breath — atmosphere band */}
  <ImageBand
    src="/placeholders/workshop.svg"
    alt="Hands at work on a workbench in natural light."
    note="Atmosphere band — maker workshop bench, natural side light, hands at work"
    kicker="The same hand on every part"
    line="One operator who knows your whole setup — not a queue, not a reseller."
  />

  {/* Prove — how we work (the operating loop) */}
  <div id="how-we-work" class="scroll-mt-20">
    <LoopStrip />
  </div>

  {/* Prove — the offer as one coherent operation */}
  <OfferClusters />

  {/* Differentiate — the dark, cinematic beat */}
  <PrincipleGrid />

  {/* Point — conversation, not funnel */}
  <HomeClose />
</BaseLayout>

<script>
  // Restrained reveal-on-scroll. Only armed when JS runs and motion is allowed;
  // otherwise content is shown immediately and fully (CD §10, §16).
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const targets = document.querySelectorAll<HTMLElement>("[data-animate]");
  if (!reduce && "IntersectionObserver" in window && targets.length) {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in");
            obs.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
    );
    targets.forEach((el) => io.observe(el));
  }
</script>
