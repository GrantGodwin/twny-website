---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/home/Hero.astro";
import OperatingLayer from "../components/home/OperatingLayer.astro";
import Button from "../components/ui/Button.astro";
import { hiddenLayer, principles } from "../data/offer";
---

<BaseLayout
  title="twny — Simplifying the technology behind your business"
  description="Microsoft 365, websites, domains, backup, AI and automation — the technology behind your Australian small business, looked after as one. A boutique technology practice."
  heroHeader={true}
>
  {/* 1 — CONFIDENCE */}
  <Hero />

  {/* 2 — THE HIDDEN TECHNOLOGY LAYER */}
  <section class="bg-paper text-ink">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-24 lg:py-32">
      <div class="grid gap-12 lg:grid-cols-[0.82fr_1.18fr] lg:gap-16">
        <div data-animate>
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-mineral">
            Behind the everyday
          </p>
          <h2 class="mt-6 max-w-md font-display text-4xl font-semibold leading-[1.04] text-balance sm:text-5xl">
            Every business runs on technology it never thinks about.
          </h2>
        </div>

        <div data-animate>
          <p class="max-w-lg text-lg leading-relaxed text-steel text-pretty">
            Until something stops. Then it's suddenly all you can think about —
            and you're calling whoever set it up, hoping they remember how it fits
            together.
          </p>

          <ul class="mt-12 border-t border-line">
            {
              hiddenLayer.map((item) => (
                <li class="border-b border-line py-5">
                  <p class="font-display text-xl font-medium leading-snug text-ink text-pretty sm:text-2xl">
                    {item}
                  </p>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* 3 — SIMPLIFICATION (signature component) */}
  <OperatingLayer />

  {/* 4 — TRUST */}
  <section class="bg-paper text-ink">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-24 lg:py-32">
      <div class="grid gap-14 lg:grid-cols-[1.05fr_0.95fr] lg:gap-20">
        <div data-animate>
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-mineral">
            Where you stand
          </p>
          <h2 class="mt-6 max-w-md font-display text-4xl font-semibold leading-[1.04] text-balance sm:text-5xl">
            Handled doesn't mean handed over.
          </h2>
          <ul class="mt-12 grid gap-x-10 gap-y-9 sm:grid-cols-2">
            {
              principles.map((p) => (
                <li class="border-l-2 border-mineral pl-5">
                  <h3 class="font-display text-lg font-semibold text-ink">
                    {p.title}
                  </h3>
                  <p class="mt-2 text-sm leading-relaxed text-steel text-pretty">
                    {p.blurb}
                  </p>
                </li>
              ))
            }
          </ul>
        </div>

        <div data-animate class="lg:border-l lg:border-line lg:pl-16">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-mineral">
            Priced in the open
          </p>
          <h2 class="mt-6 font-display text-4xl font-semibold leading-[1.04] text-balance sm:text-5xl">
            You'll see the number first.
          </h2>
          <p class="mt-6 max-w-md text-base leading-relaxed text-steel text-pretty">
            Every price is published — nothing waiting behind a sales call. Pay
            annually (two months free) or monthly with no lock-in; the service is
            the same either way. All prices in AUD, ex-GST.
          </p>
          <div class="mt-8">
            <Button href="/pricing" variant="mineral">See pricing</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* 5 — INVITATION */}
  <section class="relative isolate overflow-hidden bg-sand text-ink">
    <div
      class="absolute inset-0 bg-[radial-gradient(80%_130%_at_14%_50%,#123440_0%,rgba(10,13,17,0)_60%)]"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-6xl px-5 sm:px-8 py-24 lg:py-32">
      <div
        data-animate
        class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center"
      >
        <div>
          <h2 class="max-w-2xl font-display text-4xl font-semibold leading-[1.02] text-balance sm:text-5xl lg:text-6xl">
            Tell us what you need; we'll recommend a starting point.
          </h2>
          <p class="mt-6 max-w-md text-lg leading-relaxed text-steel text-pretty">
            No pressure, no sales funnel — a short conversation, then a clear
            recommendation. Including the honest answer if you need less than you
            think.
          </p>
        </div>
        <div class="lg:justify-self-end">
          <Button href="/contact" variant="ember">Tell us what you need</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const targets = document.querySelectorAll<HTMLElement>("[data-animate]");
  if (!reduce && "IntersectionObserver" in window && targets.length) {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in");
            obs.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
    );
    targets.forEach((el) => io.observe(el));
  }
</script>
