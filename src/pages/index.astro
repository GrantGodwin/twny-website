---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/home/Hero.astro";
import CapabilityIcon from "../components/home/CapabilityIcon.astro";
import Button from "../components/ui/Button.astro";
import { capabilities, consistency, offerCards, principles } from "../data/offer";
---

<BaseLayout
  title="twny — Simplifying the technology behind your business"
  description="A boutique Australian technology practice. We look after the Microsoft 365, websites, domains, backup and automation behind your business — one accountable operator, fewer moving parts, and clean ownership you keep."
  heroHeader={true}
>
  {/* HERO */}
  <Hero />

  {/* WHAT WE LOOK AFTER — full-width editorial header, then four wide
      capability panels. No relationship band here — that becomes its own
      "Why TWNY" section later. */}
  <section id="what-we-look-after" class="bg-paper text-ink">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 lg:py-28">
      <div data-animate class="max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-mineral">
          What we look after
        </p>
        <h2 class="mt-6 font-display text-3xl font-semibold leading-[1.07] text-balance sm:text-4xl">
          Technology shouldn't be another job.
        </h2>
        <p class="mt-5 max-w-xl text-sm leading-relaxed text-steel text-pretty">
          We look after the technology behind your business — so things
          run smoothly day to day, and you have more time for the work
          that actually matters.
        </p>
      </div>

      <div
        data-animate
        class="capability-grid mt-5 grid grid-cols-1 sm:grid-cols-2 lg:mt-9 lg:grid-cols-4"
      >
        {
          capabilities.map((c) => (
            <div class="capability-item flex flex-col items-center text-center">
              <CapabilityIcon name={c.icon} class="h-16 w-16 text-mineral" />
              <h3 class="mt-5 font-display text-xl font-semibold leading-snug text-ink whitespace-nowrap lg:text-2xl">
                {c.heading}
              </h3>
              <p class="mt-5 max-w-[15rem] text-[0.9rem] leading-relaxed text-steel/85 text-pretty">
                {c.body}
              </p>
            </div>
          ))
        }
      </div>

      <div data-animate class="mt-16 lg:mt-20">
        <Button href="/#services" variant="mineral">
          See how we can help
        </Button>
      </div>
    </div>
  </section>

  {/* HOW WE WORK — quiet editorial section. Not a process: no steps, no
      sequence, no diagram. Three enduring statements about what it feels
      like to be a client, set with whitespace and type hierarchy alone. */}
  <section id="how-we-work" class="bg-sand text-ink">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 lg:py-28">
      <div class="max-w-2xl">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-mineral">
          How we work
        </p>
        <h2 class="mt-6 font-display text-3xl font-semibold leading-[1.07] text-balance sm:text-4xl">
          What stays the same.
        </h2>
        <p class="mt-5 max-w-xl text-sm leading-relaxed text-steel text-pretty">
          Every business we work with is different.
        </p>
        <p class="mt-4 max-w-xl text-sm leading-relaxed text-steel text-pretty">
          What we bring to each one isn't: clear ownership, honest pricing and
          early conversations before small issues become big ones.
        </p>
      </div>

      <div class="mt-16 max-w-2xl lg:mt-20">
        {
          consistency.map((point, i) => (
            <div class:list={["py-8", i > 0 && "border-t border-line"]}>
              <h3 class="font-display text-xl font-semibold leading-snug text-ink sm:text-2xl">
                {point.heading}
              </h3>
              <p class="mt-3 max-w-xl text-sm leading-relaxed text-steel text-pretty">
                {point.body}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* THE OFFER — heading left, three panels right, info bar below (id for footer) */}
  <section id="services" class="bg-paper text-ink">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 lg:py-28">
      <div class="grid gap-12 lg:grid-cols-[0.3fr_0.7fr] lg:gap-16">
        <div data-animate>
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-mineral">
            The offer
          </p>
          <h2 class="mt-6 max-w-xs font-display text-3xl font-semibold leading-[1.07] text-balance sm:text-4xl">
            Two clusters, one operation.
          </h2>
          <p class="mt-5 max-w-xs text-sm leading-relaxed text-steel text-pretty">
            Everything sits on one setup we own and look after — not four
            disconnected services.
          </p>
        </div>

        <div data-animate>
          <div class="grid gap-4 sm:grid-cols-3">
            {
              offerCards.map((card) => (
                <div class="flex flex-col rounded-sm border border-line bg-band p-6">
                  <span
                    class:list={[
                      "flex h-8 w-8 items-center justify-center rounded-full",
                      card.accent === "ember" ? "bg-ember/15" : "bg-mineral/15",
                    ]}
                  >
                    <span
                      class:list={[
                        "h-2 w-2 rounded-full",
                        card.accent === "ember" ? "bg-ember" : "bg-mineral",
                      ]}
                    />
                  </span>
                  <h3 class="mt-4 font-display text-lg font-semibold text-ink">
                    {card.title}
                  </h3>
                  <p class="mt-2 text-sm leading-relaxed text-steel text-pretty">
                    {card.blurb}
                  </p>
                  {card.items && (
                    <ul class="mt-4 space-y-2 border-t border-line pt-4">
                      {card.items.map((item) => (
                        <li class="flex gap-2 text-sm leading-snug text-steel">
                          <span class="text-mineral" aria-hidden="true">
                            ✓
                          </span>
                          <span class="text-pretty">{item}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              ))
            }
          </div>

          <div
            class="mt-4 rounded-sm border border-line border-l-2 border-l-mineral bg-sand px-5 py-4"
          >
            <p class="text-sm leading-relaxed text-steel text-pretty">
              It all sits on one setup we own and look after — your email, files,
              identity, backup, domain and, where it applies, the website — with
              one source of truth and clean ownership you can always take with you.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* WHY WE'RE DIFFERENT + PRICING — split dark band */}
  <section class="bg-sand text-ink">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 lg:py-28">
      <div class="grid gap-14 lg:grid-cols-[1.1fr_0.9fr] lg:gap-20">
        <div data-animate>
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-mineral">
            Why we're different
          </p>
          <div class="mt-8 grid gap-x-10 gap-y-9 sm:grid-cols-2">
            {
              principles.map((p) => (
                <div>
                  <div class="flex items-center gap-2.5">
                    <span class="flex h-6 w-6 items-center justify-center rounded-full bg-mineral/15">
                      <span class="h-1.5 w-1.5 rounded-full bg-mineral" />
                    </span>
                    <h3 class="font-display text-base font-semibold text-ink">
                      {p.title}
                    </h3>
                  </div>
                  <p class="mt-2.5 text-sm leading-relaxed text-steel text-pretty">
                    {p.blurb}
                  </p>
                </div>
              ))
            }
          </div>
        </div>

        <div data-animate class="lg:border-l lg:border-line lg:pl-16">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-mineral">
            Pricing
          </p>
          <h2 class="mt-6 font-display text-3xl font-semibold leading-[1.05] text-balance sm:text-4xl">
            Priced in the open.
          </h2>
          <p class="mt-5 max-w-sm text-sm leading-relaxed text-steel text-pretty">
            Two ways to pay: annual commitment (two months free) or monthly flex
            (no lock-in). Every price is published — nothing hidden behind a sales
            call.
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-x-6 gap-y-4">
            <Button href="/pricing" variant="mineralSolid">See pricing</Button>
            <Button href="/productivity" variant="mineral">
              Explore Productivity
            </Button>
          </div>
          <p class="mt-6 font-mono text-xs text-steel">
            All prices are in Australian dollars and exclude GST.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* CONVERSION BAND */}
  <section class="relative isolate overflow-hidden bg-band text-ink">
    <div
      class="absolute inset-0 bg-[radial-gradient(70%_140%_at_15%_50%,rgba(19,58,71,0.6)_0%,rgba(22,29,38,0)_60%)]"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-6xl px-5 sm:px-8 py-12 lg:py-16">
      <div
        data-animate
        class="flex flex-col gap-7 lg:flex-row lg:items-center lg:justify-between lg:gap-10"
      >
        <h2 class="max-w-md font-display text-2xl font-semibold leading-[1.12] text-balance sm:text-3xl">
          Tell us what you need; we'll recommend a starting point.
        </h2>
        <p class="max-w-xs text-sm leading-relaxed text-steel text-pretty">
          No pressure, no sales funnel. A short conversation, then a clear
          recommendation.
        </p>
        <div class="shrink-0">
          <Button href="/contact" variant="ember">Tell us what you need</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* "What we look after" capability columns — quiet separators between
     columns (vertical) and rows (horizontal) as the grid wraps, without
     boxed cards. align-items: start keeps each item's own content height,
     so a divider never stretches taller than the panel it sits beside. */
  .capability-grid {
    row-gap: 4rem;
    column-gap: 2rem;
    align-items: start;
  }
  .capability-item {
    position: relative;
  }
  @media (max-width: 639px) {
    .capability-item + .capability-item::after {
      content: "";
      position: absolute;
      top: 0;
      left: 10%;
      right: 10%;
      height: 1px;
      background: linear-gradient(
        to right,
        transparent,
        color-mix(in srgb, var(--line) 48%, transparent) 30%,
        color-mix(in srgb, var(--line) 48%, transparent) 70%,
        transparent
      );
    }
    .capability-item + .capability-item {
      padding-top: 2.5rem;
    }
  }
  @media (min-width: 640px) and (max-width: 1023px) {
    .capability-item:nth-child(n + 3)::after {
      content: "";
      position: absolute;
      top: 0;
      left: 10%;
      right: 10%;
      height: 1px;
      background: linear-gradient(
        to right,
        transparent,
        color-mix(in srgb, var(--line) 48%, transparent) 30%,
        color-mix(in srgb, var(--line) 48%, transparent) 70%,
        transparent
      );
    }
    .capability-item:nth-child(n + 3) {
      padding-top: 2.5rem;
    }
    .capability-item:nth-child(even)::before {
      content: "";
      position: absolute;
      top: 16%;
      bottom: 16%;
      left: -1rem;
      width: 1px;
      background: linear-gradient(
        to bottom,
        transparent,
        color-mix(in srgb, var(--line) 48%, transparent) 30%,
        color-mix(in srgb, var(--line) 48%, transparent) 70%,
        transparent
      );
    }
  }
  @media (min-width: 1024px) {
    .capability-item:not(:first-child)::before {
      content: "";
      position: absolute;
      top: 16%;
      bottom: 16%;
      left: -1rem;
      width: 1px;
      background: linear-gradient(
        to bottom,
        transparent,
        color-mix(in srgb, var(--line) 48%, transparent) 30%,
        color-mix(in srgb, var(--line) 48%, transparent) 70%,
        transparent
      );
    }
  }
</style>

<script>
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const targets = document.querySelectorAll<HTMLElement>("[data-animate]");
  if (!reduce && "IntersectionObserver" in window && targets.length) {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("in");
            obs.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
    );
    targets.forEach((el) => io.observe(el));
  }
</script>
